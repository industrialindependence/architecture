# Postmark transactional email — required for /api/contact (the contact form)
# Get a server token from your Postmark account: https://account.postmarkapp.com/servers
POSTMARK_SERVER_TOKEN=

# Verified sender address in your Postmark account (e.g. hello@industrialindependence.org)
POSTMARK_FROM_EMAIL=

# Where contact-form submissions get delivered
CONTACT_DESTINATION_EMAIL=

# Postmark message stream (default 'outbound'; use a transactional stream)
POSTMARK_MESSAGE_STREAM=outbound
