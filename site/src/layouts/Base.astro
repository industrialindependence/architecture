---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  current?: string;
}

const {
  title,
  description = 'Industrial Independence Architecture — an architectural principle for industrial infrastructure.',
  current = ''
} = Astro.props;

const fullTitle = title === 'Industrial Independence Architecture'
  ? title
  : `${title} · IIA`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).toString()} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <Header current={current} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
