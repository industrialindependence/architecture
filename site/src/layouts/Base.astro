---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { stripLocalePrefix, withLocale } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  current?: string;
  ogCard?: string;
  pageType?: 'WebPage' | 'Article' | 'AboutPage' | 'ContactPage' | 'CollectionPage';
  datePublished?: string;
  dateModified?: string;
  locale?: 'en' | 'fr';
}

const {
  title,
  description,
  current = '',
  ogCard = 'home',
  pageType = 'WebPage',
  datePublished,
  dateModified,
  locale: propLocale
} = Astro.props;

const locale = (propLocale ?? Astro.locals.locale ?? 'en') as 'en' | 'fr';
const pageDescription = description
  ?? (locale === 'fr'
    ? 'Industrial Independence Architecture - un principe architectural pour les infrastructures industrielles.'
    : 'Industrial Independence Architecture - an architectural principle for industrial infrastructure.');

const fullTitle = title === 'Industrial Independence Architecture' || title === 'Industrial Independence Alliance'
  ? title
  : `${title} · IIA`;

const pagePath = Astro.locals.pagePath ?? stripLocalePrefix(Astro.url.pathname);
const canonicalPath = withLocale(pagePath, locale);
const canonicalUrl = new URL(canonicalPath, Astro.site).toString();
// Bump OG_V whenever the OG card design/content changes. LinkedIn (and
// other scrapers) mirror images by URL and never re-fetch an unchanged
// one — versioning the URL is what forces a fresh pull.
const OG_V = '20260518b';
const ogImageUrl = new URL(`/og-card/${ogCard}.png?v=${OG_V}`, Astro.site).toString();
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://industrialindependence.org';
const englishUrl = new URL(withLocale(pagePath, 'en'), Astro.site).toString();
const frenchUrl = new URL(withLocale(pagePath, 'fr'), Astro.site).toString();

const organization = {
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: 'Industrial Independence Alliance',
  alternateName: 'IIA',
  url: `${siteUrl}/`,
  logo: `${siteUrl}/icons/icon-512.png`,
  founder: {
    '@type': 'Person',
    name: 'Daniel "Riverman" Caudle',
    email: 'mailto:river@riverman.io',
    jobTitle: 'Architect, ISA-99 / IEC 62443 committee member'
  },
  sameAs: [
    'https://github.com/industrialindependence/architecture'
  ]
};

const website = {
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  url: `${siteUrl}/`,
  name: 'Industrial Independence Alliance',
  description: locale === 'fr'
    ? 'Souverainete operationnelle pour les infrastructures industrielles.'
    : 'Operational sovereignty for industrial infrastructure.',
  publisher: { '@id': `${siteUrl}/#organization` },
  inLanguage: locale,
  license: 'https://creativecommons.org/licenses/by-sa/4.0/'
};

const pageEntity: Record<string, unknown> = {
  '@type': pageType,
  '@id': `${canonicalUrl}#page`,
  url: canonicalUrl,
  name: fullTitle,
  description: pageDescription,
  isPartOf: { '@id': `${siteUrl}/#website` },
  inLanguage: locale,
  primaryImageOfPage: ogImageUrl
};
if (pageType === 'Article') {
  pageEntity['headline'] = title;
  pageEntity['author'] = { '@id': `${siteUrl}/#organization` };
  pageEntity['publisher'] = { '@id': `${siteUrl}/#organization` };
  pageEntity['image'] = ogImageUrl;
  if (datePublished) pageEntity['datePublished'] = datePublished;
  if (dateModified) pageEntity['dateModified'] = dateModified;
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [organization, website, pageEntity]
};
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0e0d0b" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafaf7" media="(prefers-color-scheme: light)" />
    <title>{fullTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content="Industrial Independence Alliance" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={englishUrl} />
    <link rel="alternate" hreflang="fr" href={frenchUrl} />
    <link rel="alternate" hreflang="x-default" href={englishUrl} />

    <meta property="og:site_name" content="Industrial Independence Alliance" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={pageType === 'Article' ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="image" property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />
    <meta property="og:image:alt" content={`${fullTitle} - Industrial Independence Alliance`} />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${fullTitle} - Industrial Independence Alliance`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/favicon.svg" color="#d96a4f" />

    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="skip">{locale === 'fr' ? 'Aller au contenu' : 'Skip to content'}</a>
    <Header current={current} locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
