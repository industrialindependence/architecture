---
import Base from '../layouts/Base.astro';
import FractalDiagram from '../components/diagrams/FractalDiagram.astro';
import PillarIcon from '../components/PillarIcon.astro';
import { withLocale } from '../lib/i18n';

export const prerender = false;
const locale = (Astro.locals.locale ?? 'en') as 'en' | 'fr';
const readLabel = locale === 'fr' ? 'Lire ->' : 'Read ->';
---

<Base
  title="Industrial Independence Alliance"
  description={locale === 'fr'
    ? "Souverainete operationnelle pour les infrastructures industrielles. L'Industrial Independence Alliance publie La Philosophie et L'Architecture (IIA)."
    : 'Operational sovereignty for industrial infrastructure. The Industrial Independence Alliance publishes The Philosophy and The Architecture (IIA).'}
  current="home"
  ogCard="home"
  locale={locale}
>
  <section class="landing-hero">
    <div class="container landing-hero-inner">
      <p class="eyebrow mono">Industrial Independence Alliance</p>
      <h1 class="display">
        {locale === 'fr' ? 'Souverainete operationnelle' : 'Operational sovereignty'}<br />{locale === 'fr' ? 'pour les infrastructures industrielles' : 'for industrial infrastructure'}<span class="dot">.</span>
      </h1>
      <p class="lede">
        {locale === 'fr'
          ? "Les systemes de controle agissent sur la physique, pas sur l'information. L'Alliance publie ce qui decoule de cette distinction en cinq piliers : le terrain dans lequel l'exploitation travaille, le probleme qui lui fait obstacle, la position que nous tenons, la philosophie avec laquelle nous pensons et l'architecture qui operationalise les quatre autres."
          : 'Control systems act on physics, not on information. The Alliance publishes what follows from that distinction in five pillars: the field operations works in, the problem standing in its way, the claim we hold to, the philosophy we think with, and the architecture that operationalizes all four.'}
      </p>
      <p class="onramp mono">
        {locale === 'fr' ? 'Nouveau dans l’automatisation industrielle, les ICS ou les technologies operationnelles ?' : 'New to industrial automation, ICS, or operational technology?'}
        <a href={withLocale('/architecture/docs/introduction/', locale)}>{locale === 'fr' ? 'Commencez ici' : 'Start here'} &rarr;</a>
      </p>
    </div>
  </section>

  <section class="pillars">
    <div class="container">
      <p class="pillars-eyebrow mono">&sect; {locale === 'fr' ? 'Cinq piliers' : 'Five pillars'}</p>
      <p class="pillars-intro">
        {locale === 'fr'
          ? 'Observation -> observation -> position -> position -> artefact. Lisez de haut en bas ; chaque pilier est le sol du suivant.'
          : 'Observation -> observation -> position -> position -> artifact. Read top to bottom; each pillar is the ground of the next.'}
      </p>

      <ol class="pillar-row pillar-row-diag">
        <li>
          <a href={withLocale('/field/', locale)} class="pillar-card">
            <span class="pillar-head">
              <PillarIcon pillar="field" size={26} />
              <span class="pillar-num mono">I &middot; {locale === 'fr' ? 'observation' : 'observation'}</span>
            </span>
            <h2 class="pillar-title">{locale === 'fr' ? 'Le terrain' : 'The Field'}<span class="dot">.</span></h2>
            <p class="pillar-blurb">
              {locale === 'fr'
                ? "Le lieu du travail d'exploitation. Des types de lieux, de personnes et de defaillances bien concrets — le terrain vecu qui donne sa forme a l'architecture."
                : 'Where operations works. Specific kinds of places, specific kinds of people, specific kinds of failures — the lived ground the architecture is shaped by.'}
            </p>
            <span class="pillar-cta mono">{readLabel}</span>
          </a>
        </li>
        <li>
          <a href={withLocale('/problem/', locale)} class="pillar-card">
            <span class="pillar-head">
              <PillarIcon pillar="problem" size={26} />
              <span class="pillar-num mono">II &middot; {locale === 'fr' ? 'observation' : 'observation'}</span>
            </span>
            <h2 class="pillar-title">{locale === 'fr' ? 'Le probleme' : 'The Problem'}<span class="dot">.</span></h2>
            <p class="pillar-blurb">
              {locale === 'fr'
                ? "Ce qui fait obstacle. Le marche, l'IT et les propres gardiens du terrain. Des piles fermees, du theatre securitaire, un savoir garde par ceux qui devraient l'enseigner."
                : "What stands in the way. The market, IT, and the field's own gatekeepers. Closed stacks, security theater, knowledge hoarded by those who should be teaching."}
            </p>
            <span class="pillar-cta mono">{readLabel}</span>
          </a>
        </li>
        <li>
          <a href={withLocale('/claim/', locale)} class="pillar-card">
            <span class="pillar-head">
              <PillarIcon pillar="claim" size={26} />
              <span class="pillar-num mono">III &middot; {locale === 'fr' ? 'position' : 'position'}</span>
            </span>
            <h2 class="pillar-title">{locale === 'fr' ? 'Notre position' : 'Our Claim'}<span class="dot">.</span></h2>
            <p class="pillar-blurb">
              {locale === 'fr'
                ? "Ce qui est du aux operations. Ce qui doit etre possede, repris, formalise. Des SLA qui correspondent a la production. Des contrats avec l'IT. La separation comme architecture, pas comme politique."
                : 'What operations is owed. What must be owned, taken back, formalized. SLAs that match production. Contracts with IT. Separation as architecture, not policy.'}
            </p>
            <span class="pillar-cta mono">{readLabel}</span>
          </a>
        </li>
      </ol>

      <ol class="pillar-row pillar-row-resp" start="4">
        <li>
          <a href={withLocale('/philosophy/', locale)} class="pillar-card pillar-card-wide">
            <span class="pillar-head">
              <PillarIcon pillar="philosophy" size={28} />
              <span class="pillar-num mono">IV &middot; {locale === 'fr' ? 'position' : 'position'}</span>
            </span>
            <h2 class="pillar-title">{locale === 'fr' ? 'Notre philosophie' : 'Our Philosophy'}<span class="dot">.</span></h2>
            <p class="pillar-blurb">
              {locale === 'fr'
                ? "Notre facon de penser le substrat. SRP — Securite, Fiabilite, Performance — gouverne l'ACS. L'information est gouvernee par CIA. Sept principes en decoulent."
                : 'How we think about the substrate. SRP — Safety, Reliability, Performance — governs the ACS. Information is governed by CIA. Seven principles follow.'}
            </p>
            <ul class="pillar-meta mono">
              <li>SRP Triad &middot; <span class="dim">{locale === 'fr' ? 'd’apres Robert Radvanovsky / Infracritical' : 'after Robert Radvanovsky / Infracritical'}</span></li>
              <li>PERA+ alignment &middot; <span class="dim">Gary Rathwell / Entercon</span></li>
            </ul>
            <span class="pillar-cta mono">{readLabel}</span>
          </a>
        </li>
        <li>
          <a href={withLocale('/architecture/', locale)} class="pillar-card pillar-card-wide">
            <span class="pillar-head">
              <PillarIcon pillar="architecture" size={28} />
              <span class="pillar-num mono">V &middot; {locale === 'fr' ? 'artefact' : 'artifact'}</span>
            </span>
            <h2 class="pillar-title">{locale === 'fr' ? "L'architecture" : 'The Architecture'}<span class="dot">.</span></h2>
            <p class="pillar-blurb">
              {locale === 'fr'
                ? "Industrial Independence Architecture (IIA). Une unite autonome a la tete de chaque zone d'un reseau industriel. Identique a tous les niveaux. Seule l'echelle change."
                : 'Industrial Independence Architecture (IIA). One self-contained unit at every zone of an industrial network. Identical at every level. Scope is the only thing that changes.'}
            </p>
            <ul class="pillar-meta mono">
              <li>{locale === 'fr' ? 'Passerelle de bordure securisee · le fractal · contrats de donnees' : 'Secure edge gateway · the fractal · data contracts'}</li>
              <li>SL3 floor &middot; SL4 via hardware diode</li>
              <li>IEC&nbsp;62443 &middot; ISA-95 &middot; CESMII&nbsp;i3X</li>
            </ul>
            <span class="pillar-cta mono">{readLabel}</span>
          </a>
        </li>
      </ol>
    </div>
  </section>

  <section class="fractal-section">
    <div class="container fractal-inner">
      <p class="fractal-eyebrow mono">&sect; {locale === 'fr' ? 'Le fractal' : 'The fractal'}</p>
      <p class="fractal-intro">
        {locale === 'fr'
          ? "Une boite a la tete de chaque zone — la passerelle de bordure securisee. A l'interieur se trouvent les donnees du systeme de controle ; a la boite, elles deviennent de l'information pour les consommateurs. Les dispositifs internes peuvent etre a n'importe quel niveau de securite. La meme unite a chaque zone, quelle que soit l'echelle."
          : 'A box at the head of every zone — the secure edge gateway. Inside is control system data; at the box it becomes information for consumers. Devices inside can be any security level. The same unit at every zone, regardless of scope.'}
      </p>
      <FractalDiagram />
    </div>
  </section>

  <section class="implementations">
    <div class="container">
      <p class="impl-eyebrow mono">&sect; {locale === 'fr' ? 'Implementations de reference' : 'Reference implementations'}</p>
      <p class="impl-intro">
        {locale === 'fr'
          ? 'A quoi ressemblent les principes dans des logiciels effectivement livres. Produits independants, construits sur IIA.'
          : 'What the principles look like in shipped software. Independent products, built on IIA.'}
      </p>
      <div class="impl-grid">
        <a class="impl-card" href="https://www.grassmarlin.com" rel="noopener">
          <p class="impl-label mono">MarlinSpike</p>
          <h3 class="impl-title">{locale === 'fr' ? 'Le GrassMarlin moderne' : 'The modern GrassMarlin'}<span class="dot">.</span></h3>
          <p class="impl-blurb">
            {locale === 'fr'
              ? "Le successeur maintenu et multi-utilisateur de GrassMarlin de la NSA (fin de vie 2017). Atelier open source de topologie OT/ICS passive. Les captures entrent, zero paquet ne sort."
              : 'The maintained, multi-user successor to NSA’s GrassMarlin (EOL 2017). Open-source passive OT/ICS topology workbench. Captures in, zero packets out.'}
          </p>
          <span class="impl-cta mono">grassmarlin.com &rarr;</span>
        </a>
        <a class="impl-card" href="https://www.conversationalfactory.com" rel="noopener">
          <p class="impl-label mono">Conversational Factory</p>
          <h3 class="impl-title">{locale === 'fr' ? 'Une usine a laquelle on peut parler' : 'A factory you can talk to'}<span class="dot">.</span></h3>
          <p class="impl-blurb">
            {locale === 'fr'
              ? "Plateforme OT en lecture seule. DPI temoin passif sur 34 protocoles, lac de donnees medallion, surface de requete i3X v1 · MCP pour operateurs et clients IA. Chaque reponse est liee a une chaine d'audit append-only."
              : 'Read-only OT platform. Passive wire-witness DPI across 34 protocols, medallion data lake, i3X v1 · MCP query surface for operators and AI clients. Every answer bound to an append-only audit chain.'}
          </p>
          <span class="impl-cta mono">conversationalfactory.com &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="bridge">
    <div class="container bridge-inner">
      <p class="bridge-eyebrow mono">{locale === 'fr' ? 'La souverainete relie les deux' : 'Sovereignty bridges the two'}</p>
      <p class="bridge-line">
        {locale === 'fr'
          ? "L'independance industrielle n'est pas une position technologique. C'est une position de <strong>souverainete operationnelle</strong>. L'entite qui controle l'infrastructure d'automatisation controle l'operation."
          : 'Industrial independence is not a technology position. It is an <strong>operational sovereignty</strong> position. The entity that controls the automation infrastructure controls the operation.'}
      </p>
    </div>
  </section>
</Base>

<style>
  .landing-hero {
    padding: 5.5rem 0 3.5rem;
    background:
      radial-gradient(ellipse 80% 60% at 25% 10%, var(--accent-soft), transparent 60%),
      var(--bg);
    border-bottom: 1px solid var(--rule-soft);
  }
  .landing-hero-inner { max-width: 60rem; }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.74rem;
    color: var(--accent);
    margin: 0 0 1.4rem;
    font-weight: 500;
  }
  .display {
    font-size: clamp(2.2rem, 5vw + 0.4rem, 4.1rem);
    line-height: 0.96;
    letter-spacing: -0.034em;
    font-weight: 700;
    margin: 0 0 1.6rem;
    font-family: var(--font-display);
    text-wrap: balance;
  }
  .display .dot { color: var(--accent); }
  .lede {
    font-size: 1.18rem;
    line-height: 1.55;
    max-width: 60ch;
    color: var(--ink);
    margin: 0 0 1.6rem;
  }

  .onramp {
    font-size: 0.84rem;
    color: var(--ink-mute);
    letter-spacing: 0.02em;
    margin: 0;
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--rule-soft);
    border-radius: 3px;
    display: inline-block;
    background: var(--bg-elev);
  }
  .onramp a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    margin-left: 0.3rem;
  }
  .onramp a:hover { text-decoration: underline; }

  .pillars {
    padding: 3rem 0 4rem;
    border-bottom: 1px solid var(--rule-soft);
    background: var(--bg);
  }
  .pillars-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--ink-mute);
    margin: 0 0 0.6rem;
  }
  .pillars-intro {
    font-size: 1.04rem;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0 0 2rem;
  }
  .pillar-row {
    list-style: none;
    counter-reset: pillar;
    padding: 0;
    margin: 0 0 0;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--rule);
  }
  .pillar-row-diag { grid-template-columns: 1fr 1fr 1fr; }
  .pillar-row-resp {
    grid-template-columns: 1fr 1fr;
    border-top: 0;
    margin-top: -1px;
  }
  .pillar-row li {
    border-bottom: 1px solid var(--rule-soft);
    border-right: 1px solid var(--rule-soft);
  }
  .pillar-row li:last-child { border-right: 0; }
  .pillar-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 2rem clamp(1.2rem, 2.4vw, 1.8rem) 2.2rem;
    text-decoration: none;
    color: var(--ink);
    height: 100%;
    transition: background 180ms ease;
  }
  .pillar-card:hover { background: var(--accent-soft); }
  .pillar-card:hover .pillar-cta { color: var(--accent); }
  .pillar-head {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0 0 0.7rem;
  }
  .pillar-num {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin: 0;
  }
  .pillar-title {
    font-size: clamp(1.5rem, 1.8vw + 0.4rem, 2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 0.4rem;
    font-weight: 600;
    max-width: 22ch;
  }
  .pillar-title .dot { color: var(--accent); }
  .pillar-blurb {
    font-size: 0.96rem;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 42ch;
    margin: 0;
  }
  .pillar-meta {
    list-style: none;
    padding: 0;
    margin: 0.8rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    font-size: 0.76rem;
    color: var(--ink-mute);
  }
  .pillar-meta li {
    padding: 0.4rem 0;
    border-top: 1px solid var(--rule-soft);
  }
  .pillar-meta li:last-child { border-bottom: 1px solid var(--rule-soft); }
  .pillar-meta .dim { color: var(--ink-mute); opacity: 0.8; }
  .pillar-cta {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
    margin-top: auto;
    padding-top: 0.6rem;
    transition: color 180ms ease;
  }

  .fractal-section {
    padding: 4.5rem 0 4rem;
    border-bottom: 1px solid var(--rule-soft);
    background: var(--bg);
  }
  .fractal-inner {
    max-width: var(--max-wide);
  }
  .fractal-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--ink-mute);
    margin: 0 0 0.8rem;
  }
  .fractal-intro {
    font-size: 1.04rem;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0 0 1.6rem;
  }

  .implementations {
    padding: 4.5rem 0;
    border-bottom: 1px solid var(--rule-soft);
    background: var(--bg);
  }
  .impl-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.74rem;
    color: var(--accent);
    margin: 0 0 0.7rem;
  }
  .impl-intro {
    font-size: 1.08rem;
    color: var(--ink-soft);
    max-width: 70ch;
    margin: 0 0 2.2rem;
  }
  .impl-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--rule);
  }
  .impl-card {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: 2rem clamp(1.4rem, 3vw, 2.4rem) 2.2rem;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--rule-soft);
    border-right: 1px solid var(--rule-soft);
    transition: background 180ms ease;
  }
  .impl-card:last-child { border-right: 0; }
  .impl-card:hover { background: var(--accent-soft); }
  .impl-card:hover .impl-cta { color: var(--accent); }
  .impl-label {
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent);
    margin: 0;
  }
  .impl-title {
    font-size: clamp(1.4rem, 2vw + 0.4rem, 1.8rem);
    line-height: 1.1;
    letter-spacing: -0.018em;
    font-weight: 600;
    margin: 0;
    max-width: 22ch;
  }
  .impl-title .dot { color: var(--accent); }
  .impl-blurb {
    font-size: 0.98rem;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0;
    max-width: 48ch;
  }
  .impl-cta {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
    margin-top: 0.2rem;
    transition: color 160ms ease;
  }
  @media (max-width: 820px) {
    .impl-grid { grid-template-columns: 1fr; }
    .impl-card { border-right: 0; }
  }

  .bridge {
    padding: 4rem 0 5rem;
    background: var(--bg-elev);
    border-bottom: 1px solid var(--rule-soft);
  }
  .bridge-inner { max-width: 70ch; }
  .bridge-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--accent);
    margin: 0 0 1rem;
  }
  .bridge-line {
    font-size: 1.32rem;
    line-height: 1.5;
    color: var(--ink);
    margin: 0;
  }

  @media (max-width: 980px) {
    .pillar-row-diag { grid-template-columns: 1fr 1fr; }
    .pillar-row-resp { grid-template-columns: 1fr; }
    .pillar-row-diag li:nth-child(2n) { border-right: 0; }
    .pillar-row-resp li { border-right: 0; }
  }
  @media (max-width: 720px) {
    .pillar-row-diag,
    .pillar-row-resp { grid-template-columns: 1fr; }
    .pillar-row li {
      border-right: 0 !important;
      padding: 0;
    }
    .pillar-card { padding: 1.8rem clamp(1.2rem, 4vw, 2.4rem) 2rem; }
    .landing-hero { padding: 3.5rem 0 2rem; }
    .fractal-section { padding: 2.8rem 0 2.6rem; }
    .bridge { padding: 2.6rem 0 3rem; }
    .bridge-line { font-size: 1.12rem; }
  }
</style>
