---
import Base from '../layouts/Base.astro';
import { getEntry, render } from 'astro:content';
import PillarIcon from '../components/PillarIcon.astro';
import { withLocale } from '../lib/i18n';

export const prerender = false;
const locale = (Astro.locals.locale ?? 'en') as 'en' | 'fr';

const entry = await getEntry(locale === 'fr' ? 'docsFr' : 'docs', 'the-field');
if (!entry) throw new Error('the-field doc entry not found');
const { Content, headings } = await render(entry);

const tocHeadings = headings.filter((h) => h.depth === 2);
---

<Base
  title={locale === 'fr' ? 'Le terrain' : 'The Field'}
  description={locale === 'fr'
    ? "Le terrain vecu qui donne sa forme a l'Industrial Independence Architecture — des types de lieux, de personnes et de defaillances bien precis, ainsi que la reponse architecturale a chacun."
    : 'The lived ground the Industrial Independence Architecture is shaped by — specific kinds of places, specific kinds of people, specific kinds of failures, and the architectural response to each.'}
  current="field"
  ogCard="field"
  pageType="Article"
  locale={locale}
>
  <section class="pillar-hero">
    <div class="container pillar-hero-inner">
      <p class="eyebrow mono"><span class="eyebrow-icon"><PillarIcon pillar="field" size={22} /></span>{locale === 'fr' ? 'Pilier I · observation' : 'Pillar I · observation'}</p>
      <h1 class="display">
        {locale === 'fr' ? 'Le terrain' : 'The Field'}<span class="dot">.</span>
      </h1>
      <p class="lede">
        {locale === 'fr'
          ? "Le lieu ou l'exploitation travaille. Des types de lieux, de personnes et de defaillances bien precis."
          : 'Where operations works. Specific kinds of places, specific kinds of people, specific kinds of failures.'}
      </p>
      <p class="lede dim">
        {locale === 'fr'
          ? "Le terrain vecu qui donne sa forme a l'architecture. Lisez ceci d'abord ; chaque decision architecturale decoule de ces conditions."
          : 'The lived ground the architecture is shaped by. Read this first; every architectural decision is downstream of these conditions.'}
      </p>
    </div>
  </section>

  <figure class="field-hero">
    <img
      src="/field/field-conveyor-bridge.jpg"
      alt={locale === 'fr' ? 'Dessous de convoyeurs industriels sur ciel du soir' : 'Underside of industrial conveyor bridges against an evening sky'}
      width="1600"
      height="900"
      fetchpriority="high"
    />
  </figure>

  <div class="pillar-shell container">
    {tocHeadings.length > 0 && (
      <aside class="pillar-side">
        <p class="side-label mono">{locale === 'fr' ? 'Sur cette page' : 'On this page'}</p>
        <nav class="toc" aria-label={locale === 'fr' ? 'Table des matieres' : 'Table of contents'}>
          {tocHeadings.map((h) => (
            <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
          ))}
        </nav>
      </aside>
    )}
    <article class="pillar-body prose">
      <Content />
    </article>
  </div>

  <section class="field-mosaic-section">
    <div class="container">
      <p class="mosaic-eyebrow mono">{locale === 'fr' ? 'Depuis le terrain' : 'From the field'}</p>
      <div class="field-mosaic">
        <figure>
          <img src="/field/field-tailings-pond.jpg" alt={locale === 'fr' ? 'Mine a ciel ouvert avec bassin de residus gele turquoise' : 'Open-pit mine with a turquoise frozen tailings pond'} loading="lazy" />
        </figure>
        <figure>
          <img src="/field/field-winter-plant.jpg" alt={locale === 'fr' ? 'Usine de traitement hivernale dans une vallee montagneuse' : 'Winter processing plant in a mountain valley'} loading="lazy" />
        </figure>
        <figure>
          <img src="/field/field-dragline.jpg" alt={locale === 'fr' ? 'Pelle dragline travaillant dans la neige' : 'Dragline excavator working in snow'} loading="lazy" />
        </figure>
      </div>
      <p class="mosaic-caption">
        {locale === 'fr'
          ? "La ou l'architecture prend forme. Photographies de l'auteur ; installations, geographies et personnels specifiques ne sont volontairement pas identifies."
          : "Where the architecture is shaped. Author's own photographs; specific facilities, geographies, and personnel are deliberately not identified."}
      </p>
    </div>
  </section>

  <section class="pillar-next">
    <div class="container">
      <p class="next-eyebrow mono">&sect; {locale === 'fr' ? 'Ensuite' : 'Next'}</p>
      <div class="next-grid">
        <a href={withLocale('/problem/', locale)} class="next-card">
          <span class="next-num mono">{locale === 'fr' ? 'Pilier II' : 'Pillar II'}</span>
          <h3>{locale === 'fr' ? 'Le probleme' : 'The Problem'}<span class="dot">.</span></h3>
          <p>{locale === 'fr' ? "Ce qui fait obstacle. Le marche, l'IT et les propres gardiens du terrain." : "What stands in the way. The market, IT, and the field's own gatekeepers."}</p>
          <span class="next-cta mono">{locale === 'fr' ? 'Lire' : 'Read'} &rarr;</span>
        </a>
        <a href={withLocale('/claim/', locale)} class="next-card">
          <span class="next-num mono">{locale === 'fr' ? 'Pilier III' : 'Pillar III'}</span>
          <h3>{locale === 'fr' ? 'Notre position' : 'Our Claim'}<span class="dot">.</span></h3>
          <p>{locale === 'fr' ? "Ce qui est du aux operations. Ce qui doit etre possede, repris, formalise." : 'What operations is owed. What must be owned, taken back, formalized.'}</p>
          <span class="next-cta mono">{locale === 'fr' ? 'Lire' : 'Read'} &rarr;</span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .pillar-hero {
    padding: 5.5rem 0 3rem;
    background:
      radial-gradient(ellipse 60% 50% at 20% 20%, var(--accent-soft), transparent 60%),
      var(--bg);
    border-bottom: 1px solid var(--rule-soft);
  }
  .pillar-hero-inner { max-width: 64ch; }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.74rem;
    color: var(--accent);
    margin: 0 0 1.4rem;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .eyebrow-icon {
    display: inline-flex;
    line-height: 0;
  }
  .display {
    font-size: clamp(2.4rem, 5.5vw + 0.4rem, 4.4rem);
    line-height: 0.96;
    letter-spacing: -0.034em;
    font-weight: 700;
    margin: 0 0 1.4rem;
    font-family: var(--font-display);
  }
  .display .dot { color: var(--accent); }
  .lede {
    font-size: 1.2rem;
    line-height: 1.55;
    max-width: 60ch;
    color: var(--ink);
    margin: 0 0 0.9rem;
  }
  .lede.dim { color: var(--ink-soft); font-size: 1.04rem; }

  .field-hero {
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    background: var(--bg);
  }
  .field-hero img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 62vh;
    object-fit: cover;
    object-position: center 55%;
  }

  .pillar-shell {
    display: grid;
    grid-template-columns: 16rem minmax(0, 1fr);
    gap: 3.5rem;
    padding-top: 3rem;
    align-items: start;
  }
  .pillar-side {
    position: sticky;
    top: 5rem;
    align-self: start;
    border-right: 1px solid var(--rule-soft);
    padding-right: 1.4rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
  }
  .side-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-mute);
    margin: 0 0 0.8rem;
  }
  .toc {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }
  .toc-link {
    display: block;
    text-decoration: none;
    color: var(--ink-mute);
    font-size: 0.86rem;
    padding: 0.35rem 0;
    border-left: 2px solid transparent;
    padding-left: 0.7rem;
    transition: color 100ms ease, border-color 100ms ease;
    line-height: 1.35;
  }
  .toc-link:hover { color: var(--ink); border-left-color: var(--accent); }

  .pillar-body {
    max-width: 70ch;
    padding-bottom: 4rem;
  }
  .pillar-body :global(h1:first-of-type) { display: none; }
  .pillar-body :global(h2) {
    border-bottom: 1px solid var(--rule-soft);
    padding-bottom: 0.5rem;
    margin-top: 3rem;
  }
  .pillar-body :global(h3) {
    margin-top: 2rem;
    color: var(--ink);
  }
  .pillar-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    background: var(--bg-elev);
    margin: 1.6rem 0;
    padding: 1rem 1.3rem;
    color: var(--ink);
    font-style: normal;
  }
  .pillar-body :global(blockquote strong) { color: var(--accent); }

  .pillar-body :global(figure.field-figure) {
    margin: 2.2rem 0 2rem;
    padding: 0;
  }
  .pillar-body :global(figure.field-figure img) {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--rule-soft);
    background: var(--bg-elev);
  }
  .pillar-body :global(figure.field-figure figcaption) {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-mute);
    margin-top: 0.7rem;
    line-height: 1.5;
  }
  .pillar-body :global(figure.field-figure-row) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
  }
  .pillar-body :global(figure.field-figure-row img) {
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  .pillar-body :global(figure.field-figure-row figcaption) {
    grid-column: 1 / -1;
  }
  @media (max-width: 720px) {
    .pillar-body :global(figure.field-figure-row) {
      grid-template-columns: 1fr;
    }
  }

  .field-mosaic-section {
    padding: 3.4rem 0 1.4rem;
    border-top: 1px solid var(--rule-soft);
    background: var(--bg);
  }
  .mosaic-eyebrow {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-mute);
    margin: 0 0 1.2rem;
  }
  .field-mosaic {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }
  .field-mosaic figure {
    margin: 0;
  }
  .field-mosaic img {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid var(--rule-soft);
  }
  .mosaic-caption {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-mute);
    margin: 1.1rem 0 0;
    max-width: 70ch;
    line-height: 1.55;
  }
  @media (max-width: 720px) {
    .field-mosaic { grid-template-columns: 1fr; }
  }

  .pillar-next {
    padding: 4rem 0 5rem;
    background: var(--bg-elev);
    border-top: 1px solid var(--rule-soft);
  }
  .next-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.74rem;
    color: var(--ink-mute);
    margin: 0 0 1.4rem;
  }
  .next-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.4rem;
  }
  .next-card {
    display: block;
    padding: 1.6rem 1.6rem 1.8rem;
    border: 1px solid var(--rule-soft);
    border-radius: 3px;
    text-decoration: none;
    color: var(--ink);
    background: var(--bg);
    transition: background 160ms ease, border-color 160ms ease;
  }
  .next-card:hover {
    background: var(--accent-soft);
    border-color: var(--accent);
  }
  .next-card:hover .next-cta { color: var(--accent); }
  .next-num {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 0.5rem;
    display: block;
  }
  .next-card h3 {
    font-size: 1.4rem;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .next-card h3 .dot { color: var(--accent); }
  .next-card p {
    font-size: 0.94rem;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0 0 0.8rem;
    max-width: 36ch;
  }
  .next-cta {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
    transition: color 160ms ease;
  }

  @media (max-width: 980px) {
    .pillar-shell { grid-template-columns: 1fr; gap: 1.6rem; }
    .pillar-side {
      position: static;
      max-height: none;
      border-right: 0;
      border-bottom: 1px solid var(--rule-soft);
      padding-right: 0;
      padding-bottom: 1rem;
    }
    .next-grid { grid-template-columns: 1fr; }
    .pillar-hero { padding: 3.5rem 0 2.4rem; }
  }
</style>
