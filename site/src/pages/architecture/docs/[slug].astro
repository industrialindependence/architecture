---
import Base from '../../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { withLocale } from '../../../lib/i18n';

export const prerender = false;

const locale = (Astro.locals.locale ?? 'en') as 'en' | 'fr';
const PILLAR_DOCS = new Set(['the-field', 'the-problem', 'our-claim']);
const slug = Astro.params.slug ?? '';

const titleMap: Record<string, { en: string; fr: string }> = {
  'introduction': { en: 'Introduction', fr: 'Introduction' },
  'internal-architecture': { en: 'Internal Architecture', fr: 'Architecture interne' },
  'glossary': { en: 'Glossary', fr: 'Glossaire' },
  'sample-contracts': { en: 'Sample Data Contracts', fr: 'Exemples de contrats de donnees' },
  'mcp-single-box': { en: 'MCP — Single Box Quickstart', fr: 'MCP — demarrage rapide mono-boite' }
};

const descMap: Record<string, { en: string; fr: string }> = {
  'introduction': {
    en: 'A concept-first introduction to industrial automation, ICS, operational technology, and the architectural problems they create.',
    fr: "Une introduction d'abord conceptuelle a l'automatisation industrielle, aux ICS, aux technologies operationnelles et aux problemes architecturaux qu'elles creent."
  },
  'internal-architecture': {
    en: 'The canonical implementation specification: invariants, partitioning, contracts, attestation, configuration, updates, SL3 / SL4 mappings.',
    fr: "La specification canonique d'implementation : invariants, partitionnement, contrats, attestation, configuration, mises a jour, mappings SL3 / SL4."
  },
  'glossary': {
    en: 'Vocabulary used across IIA documentation. Domain, architecture, and standards terms with normative definitions.',
    fr: 'Le vocabulaire utilise dans la documentation IIA. Termes de domaine, d’architecture et de normes avec definitions normatives.'
  },
  'sample-contracts': {
    en: 'Six worked data contracts spanning internal flows, boundary contracts, device-level contracts, wireless IO, and AI-agent consumption.',
    fr: "Six contrats de donnees travailles couvrant les flux internes, les contrats de frontiere, les contrats au niveau dispositif, les E/S sans fil et la consommation par agents IA."
  },
  'mcp-single-box': {
    en: 'Operator quickstart for the smallest AI-agent consumption deployment — one box, one MCP server off-box, one AI client.',
    fr: "Demarrage rapide operateur pour le plus petit deploiement de consommation par agent IA — une boite, un serveur MCP hors boite, un client IA."
  }
};

const orderMap: Record<string, number> = {
  'introduction': 1,
  'internal-architecture': 2,
  'sample-contracts': 3,
  'mcp-single-box': 4,
  'glossary': 5
};

const localizedEntries = locale === 'fr' ? await getCollection('docsFr') : await getCollection('docs');
const englishEntries = await getCollection('docs');
const entries = localizedEntries.filter((candidate) => !PILLAR_DOCS.has(candidate.id)).length > 0
  ? localizedEntries
  : englishEntries;
const entry = entries.find((candidate) => candidate.id === slug && !PILLAR_DOCS.has(candidate.id));
if (!entry) {
  throw new Error(`Doc entry not found for slug: ${slug}`);
}

const { Content, headings } = await render(entry);
const title = entry.data.title ?? titleMap[entry.id]?.[locale] ?? titleMap[entry.id]?.en ?? entry.id;
const description = entry.data.description ?? descMap[entry.id]?.[locale] ?? descMap[entry.id]?.en;

const allDocs = entries
  .filter((d) => !PILLAR_DOCS.has(d.id))
  .map((d) => ({ id: d.id, title: titleMap[d.id]?.[locale] ?? titleMap[d.id]?.en ?? d.id, order: orderMap[d.id] ?? 99 }))
  .sort((a, b) => a.order - b.order);

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<Base title={title} description={description} current="docs" ogCard={entry.id} pageType="Article" locale={locale}>
  <div class="doc-shell container">
    <aside class="doc-side">
      <p class="side-label mono">{locale === 'fr' ? 'Documentation' : 'Documentation'}</p>
      <nav class="doc-list" aria-label={locale === 'fr' ? 'Documents' : 'Documents'}>
        {allDocs.map((d) => (
          <a
            href={withLocale(`/architecture/docs/${d.id}/`, locale)}
            class={`doc-link ${d.id === entry.id ? 'is-active' : ''}`}
          >
            <span class="doc-num mono">{String(d.order).padStart(2, '0')}</span>
            <span class="doc-title">{d.title}</span>
          </a>
        ))}
      </nav>

      {tocHeadings.length > 0 && (
        <>
          <p class="side-label mono toc-label">{locale === 'fr' ? 'Sur cette page' : 'On this page'}</p>
          <nav class="toc" aria-label={locale === 'fr' ? 'Table des matieres' : 'Table of contents'}>
            {tocHeadings.map((h) => (
              <a href={`#${h.slug}`} class={`toc-link depth-${h.depth}`}>{h.text}</a>
            ))}
          </nav>
        </>
      )}
    </aside>

    <article class="doc-body prose">
      <header class="doc-header">
        <p class="eyebrow mono">{locale === 'fr' ? 'Documentation' : 'Documentation'} &middot; {String(orderMap[entry.id] ?? '').padStart(2, '0')}</p>
        <h1>{title}</h1>
        {description && <p class="doc-lede">{description}</p>}
      </header>
      <Content />
    </article>
  </div>
</Base>

<style>
  .doc-shell {
    display: grid;
    grid-template-columns: 18rem minmax(0, 1fr);
    gap: 3.5rem;
    padding-top: 3rem;
    align-items: start;
  }
  .doc-side {
    position: sticky;
    top: 5rem;
    align-self: start;
    border-right: 1px solid var(--rule-soft);
    padding-right: 1.4rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
  }
  .side-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-mute);
    margin: 0 0 0.7rem;
  }
  .toc-label { margin-top: 2.4rem; }
  .doc-list {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    margin-bottom: 0.4rem;
  }
  .doc-link {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.4rem;
    align-items: baseline;
    padding: 0.55rem 0.6rem;
    text-decoration: none;
    color: var(--ink-soft);
    border-radius: 2px;
    border-left: 2px solid transparent;
    font-size: 0.92rem;
  }
  .doc-link:hover { color: var(--ink); background: var(--accent-soft); }
  .doc-link.is-active {
    color: var(--ink);
    border-left-color: var(--accent);
    background: var(--accent-soft);
  }
  .doc-num {
    font-size: 0.7rem;
    color: var(--ink-mute);
    letter-spacing: 0.06em;
  }
  .doc-link.is-active .doc-num { color: var(--accent); }

  .toc {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }
  .toc-link {
    display: block;
    text-decoration: none;
    color: var(--ink-mute);
    font-size: 0.84rem;
    padding: 0.32rem 0;
    border-left: 2px solid transparent;
    padding-left: 0.7rem;
    transition: color 100ms ease, border-color 100ms ease;
    line-height: 1.35;
  }
  .toc-link:hover { color: var(--ink); border-left-color: var(--accent); }
  .toc-link.depth-3 { padding-left: 1.6rem; font-size: 0.78rem; }

  .doc-body {
    max-width: 70ch;
    margin: 0;
    padding-bottom: 4rem;
  }
  .doc-header {
    margin-bottom: 2.6rem;
    padding-bottom: 1.6rem;
    border-bottom: 1px solid var(--rule-soft);
  }
  .doc-header h1 {
    font-size: clamp(2rem, 3.6vw + 0.5rem, 3rem);
    margin: 0.4rem 0 0.8rem;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--accent);
    margin: 0;
  }
  .doc-lede {
    font-size: 1.05rem;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0;
    line-height: 1.55;
  }

  .doc-body :global(h1:first-of-type) { display: none; }
  .doc-body :global(img) {
    margin: 2rem auto;
    border: 1px solid var(--rule-soft);
    border-radius: 3px;
    background: var(--bg-elev);
    padding: 0.5rem;
  }
  .doc-body :global(h2) {
    border-bottom: 1px solid var(--rule-soft);
    padding-bottom: 0.5rem;
  }

  @media (max-width: 1020px) {
    .doc-shell { grid-template-columns: 1fr; gap: 2rem; }
    .doc-side {
      position: static;
      max-height: none;
      border-right: 0;
      border-bottom: 1px solid var(--rule-soft);
      padding-right: 0;
      padding-bottom: 1.2rem;
    }
  }
</style>
