---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { withLocale } from '../../../lib/i18n';

export const prerender = false;
const locale = (Astro.locals.locale ?? 'en') as 'en' | 'fr';

const titleMap: Record<string, { en: string; fr: string }> = {
  'introduction': { en: 'Introduction', fr: 'Introduction' },
  'internal-architecture': { en: 'Internal Architecture', fr: 'Architecture interne' },
  'glossary': { en: 'Glossary', fr: 'Glossaire' },
  'sample-contracts': { en: 'Sample Data Contracts', fr: 'Exemples de contrats de donnees' },
  'mcp-single-box': { en: 'MCP — Single Box Quickstart', fr: 'MCP — demarrage rapide mono-boite' }
};

const descMap: Record<string, { en: string; fr: string }> = {
  'introduction': { en: 'Concept-first introduction for readers new to industrial automation, ICS, or operational technology. Builds the vocabulary the rest of the documentation assumes.', fr: 'Introduction conceptuelle pour les lecteurs nouveaux en automatisation industrielle, ICS ou technologies operationnelles. Construit le vocabulaire suppose par le reste de la documentation.' },
  'internal-architecture': { en: 'The canonical implementation specification. Invariants, partitioning, contracts, attestation, configuration, updates, SL3 / SL4 mappings to IEC 62443 foundational requirements. Names roles, not products.', fr: 'La specification canonique d’implementation. Invariants, partitionnement, contrats, attestation, configuration, mises a jour, mappings SL3 / SL4 vers les exigences fondamentales IEC 62443. Nomme des roles, pas des produits.' },
  'glossary': { en: 'Vocabulary used across IIA documentation. Domain terms, architectural terms, and the standards IIA aligns with.', fr: 'Vocabulaire utilise dans la documentation IIA. Termes du domaine, termes architecturaux et normes avec lesquelles IIA s’aligne.' },
  'sample-contracts': { en: 'Six worked data contracts spanning internal flows, boundary contracts (batch and query), device-level contracts, wireless IO, and AI-agent consumption.', fr: 'Six contrats de donnees travailles couvrant les flux internes, les contrats de frontiere (batch et requete), les contrats au niveau dispositif, les E/S sans fil et la consommation par agent IA.' },
  'mcp-single-box': { en: 'Operator quickstart for the smallest AI-agent consumption deployment: one box, one MCP server off-box, one AI client. Topology, identity, contract, and config-artifact pipeline.', fr: 'Demarrage rapide operateur pour le plus petit deploiement de consommation par agent IA : une boite, un serveur MCP hors boite, un client IA. Topologie, identite, contrat et pipeline d’artefacts de configuration.' }
};

const orderMap: Record<string, number> = {
  'introduction': 1,
  'internal-architecture': 2,
  'sample-contracts': 3,
  'mcp-single-box': 4,
  'glossary': 5
};

const PILLAR_DOCS = new Set(['the-field', 'the-problem', 'our-claim']);

const rawEntries = locale === 'fr'
  ? await getCollection('docsFr')
  : await getCollection('docs');
const fallbackEntries = await getCollection('docs');
const sourceEntries = rawEntries.filter((d) => !PILLAR_DOCS.has(d.id)).length > 0 ? rawEntries : fallbackEntries;
const entries = sourceEntries
  .filter((d) => !PILLAR_DOCS.has(d.id))
  .map((d) => ({
    id: d.id,
    title: titleMap[d.id]?.[locale] ?? titleMap[d.id]?.en ?? d.id,
    description: descMap[d.id]?.[locale] ?? descMap[d.id]?.en ?? '',
    order: orderMap[d.id] ?? 99
  }))
  .sort((a, b) => a.order - b.order);
---

<Base title={locale === 'fr' ? 'Documentation' : 'Documentation'} description={locale === 'fr' ? "Documentation de l'Industrial Independence Architecture." : 'Documentation for Industrial Independence Architecture.'} current="docs" ogCard="docs" pageType="CollectionPage" locale={locale}>
  <div class="container docs-index">
    <header class="page-header">
      <p class="eyebrow mono">{locale === 'fr' ? "L'architecture · Documentation" : 'The Architecture · Documentation'}</p>
      <h1>{locale === 'fr' ? 'L’ensemble complet' : 'The full set'}</h1>
      <p class="lede">
        {locale === 'fr'
          ? "Tous les documents IIA. Le principe dans le <a href='/architecture/'>README</a> est la declaration canonique ; les documents ci-dessous l'etendent sans la contredire."
          : "Every IIA document. The principle in the <a href='/architecture/'>README</a> is the canonical statement; the documents below extend it without contradicting it."}
      </p>
    </header>

    <ol class="doc-grid">
      {entries.map((d) => (
        <li class="doc-card">
          <a href={withLocale(`/architecture/docs/${d.id}/`, locale)} class="card-link">
            <span class="doc-num mono">{String(d.order).padStart(2, '0')}</span>
            <h2>{d.title}</h2>
            <p>{d.description}</p>
            <span class="read mono">{locale === 'fr' ? 'Lire ->' : 'Read ->'}</span>
          </a>
        </li>
      ))}
    </ol>
  </div>
</Base>

<style>
  .docs-index { padding-top: 3.5rem; }
  .page-header { max-width: 60ch; margin-bottom: 3rem; }
  .page-header h1 { margin: 0.3rem 0 1rem; }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--accent);
  }
  .lede { font-size: 1.06rem; color: var(--ink-soft); }

  .doc-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: 0;
    border-top: 1px solid var(--rule);
  }
  .doc-card {
    border-bottom: 1px solid var(--rule-soft);
    border-right: 1px solid var(--rule-soft);
  }
  .doc-card:last-child { border-right: 0; }
  .card-link {
    display: block;
    padding: 1.8rem 1.6rem 2rem;
    text-decoration: none;
    color: var(--ink);
    height: 100%;
    transition: background 120ms ease;
  }
  .card-link:hover {
    background: var(--accent-soft);
  }
  .card-link:hover .read { color: var(--accent); }
  .doc-num {
    display: inline-block;
    font-size: 0.74rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 0.6rem;
  }
  .card-link h2 {
    font-size: 1.3rem;
    margin: 0 0 0.6rem;
  }
  .card-link p {
    color: var(--ink-soft);
    font-size: 0.94rem;
    line-height: 1.55;
    margin: 0 0 1.2rem;
  }
  .read {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
  }

  @media (max-width: 720px) {
    .doc-card { border-right: 0; }
  }
</style>
