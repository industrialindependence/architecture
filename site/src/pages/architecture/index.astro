---
import Base from '../../layouts/Base.astro';
import { Content as ContentEn } from '../../content-src/principle/README.md';
import { Content as ContentFr } from '../../content-src/principle/README.fr.md';
import FractalDiagram from '../../components/diagrams/FractalDiagram.astro';
import BoxDiagram from '../../components/diagrams/BoxDiagram.astro';
import TwoBoxDiagram from '../../components/diagrams/TwoBoxDiagram.astro';
import PillarIcon from '../../components/PillarIcon.astro';
import { withLocale } from '../../lib/i18n';

export const prerender = false;
const locale = (Astro.locals.locale ?? 'en') as 'en' | 'fr';
const Content = locale === 'fr' ? ContentFr : ContentEn;
---

<Base title={locale === 'fr' ? "L'architecture" : 'The Architecture'} description={locale === 'fr' ? "Industrial Independence Architecture (IIA) — le principe architectural pour les infrastructures industrielles. Publie par l'Industrial Independence Alliance." : 'Industrial Independence Architecture (IIA) — the architectural principle for industrial infrastructure. Published by the Industrial Independence Alliance.'} current="architecture" ogCard="architecture" pageType="Article" locale={locale}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <p class="eyebrow mono"><span class="eyebrow-icon"><PillarIcon pillar="architecture" size={22} /></span>{locale === 'fr' ? 'Pilier V · artefact' : 'Pillar V · artifact'}</p>
        <h1 class="hero-title">
          {locale === 'fr' ? <Fragment>L'<br />architecture</Fragment> : <Fragment>The<br />Architecture</Fragment>}<span class="dot">.</span>
        </h1>
        <p class="lede">
          {locale === 'fr'
            ? <Fragment>La specification technique qui operationalise <a href={withLocale('/claim/', locale)}><strong>Notre position</strong></a> et <a href={withLocale('/philosophy/', locale)}><strong>Notre philosophie</strong></a>. Une unite autonome dans chaque zone. Identique a tous les niveaux. Seule l'echelle change.</Fragment>
            : <Fragment>The technical spec that operationalizes <a href={withLocale('/claim/', locale)}><strong>Our Claim</strong></a> and <a href={withLocale('/philosophy/', locale)}><strong>Our Philosophy</strong></a>. One self-contained unit at every zone. Identical at every level. Scope is the only thing that changes.</Fragment>}
        </p>
        <p class="lede dim">
          {locale === 'fr'
            ? "L'unite fonctionne sans connectivite amont. Pas de cloud. Pas de reseau corporate. Pas d'internet. Si la connectivite existe, elle se compose vers le haut. Si elle tombe, rien ne change sur site."
            : 'The unit works with no upstream connectivity. No cloud. No corporate network. No internet. If connectivity exists, it composes upward. If it drops, nothing changes on site.'}
        </p>
        <div class="cta-row">
          <a class="btn primary" href="#readme">{locale === 'fr' ? 'Lire le principe' : 'Read the principle'}</a>
          <a class="btn ghost" href={withLocale('/architecture/docs/introduction/', locale)}>{locale === 'fr' ? "Commencer par l'introduction" : 'Start with the introduction'}</a>
        </div>
      </div>
      <aside class="hero-meta">
        <dl>
          <div><dt>{locale === 'fr' ? 'Editeur' : 'Publisher'}</dt><dd>Industrial Independence Alliance</dd></div>
          <div><dt>{locale === 'fr' ? 'Position' : 'Stance'}</dt><dd>{locale === 'fr' ? 'Souverainete par architecture, pas par politique' : 'Sovereignty by architecture, not by policy'}</dd></div>
          <div><dt>{locale === 'fr' ? "S'aligne avec" : 'Aligns with'}</dt><dd>PERA+, IEC&nbsp;62443, ISA-95, CESMII&nbsp;i3X</dd></div>
          <div><dt>{locale === 'fr' ? 'Vise' : 'Targets'}</dt><dd>SL3 floor &middot; SL4 via diode</dd></div>
        </dl>
      </aside>
    </div>
  </section>

  <section class="thesis-strip">
    <div class="container thesis-grid">
      <div class="thesis-card">
        <p class="card-eyebrow mono">{locale === 'fr' ? 'La these' : 'The thesis'}</p>
        <p class="card-line">
          {locale === 'fr' ? <Fragment>IIA fournit le motif architectural qui fait de <strong>la souverainete l'etat par defaut</strong> plutot que l'aspiration.</Fragment> : <Fragment>IIA provides the architectural pattern that makes <strong>sovereignty the default</strong> rather than the aspiration.</Fragment>}
        </p>
      </div>
      <div class="thesis-card">
        <p class="card-eyebrow mono">{locale === 'fr' ? 'Souverainete ≠ isolement' : 'Sovereignty ≠ isolation'}</p>
        <p class="card-line">
          {locale === 'fr' ? 'Les unites sont autonomes, mais les historiens des boites adjacentes se connaissent. La conscience est mutuelle. La dependance ne l’est pas.' : 'Units are self-contained, but historians on adjacent boxes know about each other. Awareness is mutual. Dependency is not.'}
        </p>
      </div>
      <div class="thesis-card">
        <p class="card-eyebrow mono">{locale === 'fr' ? 'Application de frontiere' : 'Boundary enforcement'}</p>
        <p class="card-line">
          {locale === 'fr' ? <Fragment>L'ACS est gouverne par SRP. L'information est gouvernee par CIA. La frontiere est appliquee <strong>par l'architecture, pas par la politique</strong>.</Fragment> : <Fragment>ACS is governed by SRP. Information is governed by CIA. The boundary is enforced <strong>by architecture, not by policy</strong>.</Fragment>}
        </p>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <section class="diagrams-section">
    <div class="container">
      <div class="diagram-block">
        <p class="diag-eyebrow mono">&sect; {locale === 'fr' ? 'Le fractal' : 'The fractal'}</p>
        <p class="diag-intro">
          {locale === 'fr' ? 'Une boite a la tete de chaque zone — la passerelle de bordure securisee. A l’interieur de la zone se trouvent les donnees du systeme de controle ; a la boite, elles deviennent de l’information pour les consommateurs. Les dispositifs internes peuvent etre a n’importe quel niveau de securite. La publication sortante securisee est le seul acces externe dans la zone. Le fractal ne se collapse pas au sommet — un historien central n’est qu’une unite a portee plus large.' : 'A box at the head of every zone — the secure edge gateway. Inside the zone is control system data; at the box, it becomes information for consumers. Devices inside can be any security level. The secure outbound publish is the only external access into the zone. The fractal does not collapse at the top — a central historian is just a unit with broader scope.'}
        </p>
        <FractalDiagram />
      </div>

      <div class="diagram-block">
        <p class="diag-eyebrow mono">&sect; {locale === 'fr' ? 'La boite (CIAD)' : 'The box (CIAD)'}</p>
        <p class="diag-intro">
          {locale === 'fr' ? 'Partitionnement interne de la boite IIA. Zones entrante (cote ACS), DMZ et sortante (cote IT). Tout trafic entre les cotes transite par la DMZ. La NIC ACS est passive, RX-only.' : 'Internal partitioning of the IIA box. Inbound (ACS-facing), DMZ, and outbound (IT-facing) zones. All cross-side traffic transits the DMZ. ACS NIC is passive, RX-only.'}
        </p>
        <BoxDiagram />
      </div>

      <div class="diagram-block">
        <p class="diag-eyebrow mono">&sect; {locale === 'fr' ? 'La methode deux-boites' : 'The two-box method'}</p>
        <p class="diag-intro">
          {locale === 'fr' ? 'SL3 : une boite, segmentation logicielle. SL4 : deux boites avec diode materielle. Meme architecture logicielle dans les deux modes. Seule la topologie physique change. Attribution : Rinaldi & Workman, The Everyman’s Guide to EtherNet/IP Network Design (RTA, 2022).' : 'SL3: one box, software segmentation. SL4: two boxes with a hardware data diode. Same software architecture in both modes. Only the physical topology changes. Credited: Rinaldi & Workman, The Everyman’s Guide to EtherNet/IP Network Design (RTA, 2022).'}
        </p>
        <TwoBoxDiagram />
      </div>
    </div>
  </section>

  <hr class="rule" />

  <section class="arch-impl">
    <div class="container arch-impl-inner">
      <p class="arch-impl-eyebrow mono">&sect; {locale === 'fr' ? 'A quoi cela ressemble dans du logiciel livre' : 'What it looks like in shipped software'}</p>
      <div class="arch-impl-grid">
        <a class="arch-impl-card" href="https://www.grassmarlin.com" rel="noopener">
          <span class="arch-impl-label mono">MarlinSpike</span>
          <span class="arch-impl-text">{locale === 'fr' ? 'Le GrassMarlin moderne. Etabli de topologie OT/ICS passive — les captures entrent, zero paquet ne sort.' : 'The modern GrassMarlin. Passive OT/ICS topology workbench — captures in, zero packets out.'}</span>
          <span class="arch-impl-cta mono">grassmarlin.com &rarr;</span>
        </a>
        <a class="arch-impl-card" href="https://www.conversationalfactory.com" rel="noopener">
          <span class="arch-impl-label mono">Conversational Factory</span>
          <span class="arch-impl-text">{locale === 'fr' ? 'Plateforme OT en lecture seule. DPI temoin sur le fil sur 34 protocoles, surface de requete i3X v1 · MCP pour operateurs et clients IA.' : 'Read-only OT platform. Wire-witness DPI across 34 protocols, i3X v1 · MCP query surface for operators and AI clients.'}</span>
          <span class="arch-impl-cta mono">conversationalfactory.com &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <article class="prose container readme-body" id="readme">
    <Content />
  </article>
</Base>

<style>
  .arch-impl {
    padding: 2.4rem 0 3.4rem;
    border-bottom: 1px solid var(--rule-soft);
  }
  .arch-impl-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.74rem;
    color: var(--accent);
    margin: 0 0 1.2rem;
  }
  .arch-impl-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--rule-soft);
    border-radius: 3px;
    overflow: hidden;
  }
  .arch-impl-card {
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 0.5rem;
    padding: 1.2rem 1.4rem;
    text-decoration: none;
    color: var(--ink);
    border-right: 1px solid var(--rule-soft);
    transition: background 160ms ease;
    background: var(--bg-elev);
  }
  .arch-impl-card:last-child { border-right: 0; }
  .arch-impl-card:hover { background: var(--accent-soft); }
  .arch-impl-card:hover .arch-impl-cta { color: var(--accent); }
  .arch-impl-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
  }
  .arch-impl-text {
    font-size: 0.94rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .arch-impl-cta {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
    transition: color 160ms ease;
  }
  @media (max-width: 720px) {
    .arch-impl-grid { grid-template-columns: 1fr; }
    .arch-impl-card { border-right: 0; border-bottom: 1px solid var(--rule-soft); }
    .arch-impl-card:last-child { border-bottom: 0; }
  }
</style>

<style>
  .hero {
    padding: 4.5rem 0 3.5rem;
    background:
      linear-gradient(to bottom, var(--bg-elev), var(--bg)),
      radial-gradient(circle at 18% 0%, var(--accent-soft), transparent 55%);
    background-blend-mode: normal;
    border-bottom: 1px solid var(--rule-soft);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: 3.2rem;
    align-items: start;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.74rem;
    color: var(--accent);
    margin: 0 0 1.4rem;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .eyebrow-icon { display: inline-flex; line-height: 0; }
  .hero-title {
    font-size: clamp(2.6rem, 6.4vw + 0.5rem, 5.4rem);
    line-height: 0.96;
    letter-spacing: -0.034em;
    font-weight: 700;
    margin: 0 0 1.8rem;
    font-family: var(--font-display);
  }
  .hero-title .dot { color: var(--accent); }
  .lede {
    font-size: 1.16rem;
    line-height: 1.55;
    max-width: 56ch;
    color: var(--ink);
    margin: 0 0 1rem;
  }
  .lede.dim { color: var(--ink-soft); }
  .cta-row {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    letter-spacing: 0.04em;
    padding: 0.7rem 1.1rem;
    border-radius: 3px;
    border: 1px solid var(--rule-soft);
    transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
  }
  .btn.primary {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
  .btn.primary:hover { background: var(--accent); border-color: var(--accent); color: var(--bg); }
  .btn.ghost { background: transparent; color: var(--ink); }
  .btn.ghost:hover { border-color: var(--accent); color: var(--accent); }

  .hero-meta {
    border-left: 1px solid var(--rule-soft);
    padding-left: 1.6rem;
    margin-top: 0.4rem;
  }
  .hero-meta dl { margin: 0; }
  .hero-meta div {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0.6rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--rule-soft);
    align-items: baseline;
  }
  .hero-meta div:last-child { border-bottom: 0; }
  .hero-meta dt {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.7rem;
    color: var(--ink-mute);
  }
  .hero-meta dd {
    margin: 0;
    font-size: 0.92rem;
    color: var(--ink);
  }

  .thesis-strip {
    background: var(--bg);
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
  }
  .thesis-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
  }
  .thesis-card {
    padding: 2.4rem 1.8rem 2.4rem 0;
    border-right: 1px solid var(--rule-soft);
    position: relative;
  }
  .thesis-card:not(:first-child) { padding-left: 1.8rem; }
  .thesis-card:last-child { border-right: 0; }
  .card-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.7rem;
    color: var(--accent);
    margin: 0 0 0.8rem;
  }
  .card-line {
    font-size: 1.02rem;
    color: var(--ink);
    margin: 0;
    line-height: 1.5;
    max-width: 38ch;
  }
  .card-line strong { font-weight: 600; }

  .rule {
    margin: 0;
    border-top: 1px solid var(--rule-soft);
  }

  .diagrams-section {
    padding: 4.5rem 0 4rem;
    border-bottom: 1px solid var(--rule-soft);
    background: var(--bg);
  }
  .diagram-block { margin-bottom: 4rem; }
  .diagram-block:last-child { margin-bottom: 0; }
  .diag-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.72rem;
    color: var(--ink-mute);
    margin: 0 0 0.7rem;
  }
  .diag-intro {
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 72ch;
    margin: 0 0 1.4rem;
  }
  .readme-body { padding-top: 4rem; }
  .readme-body :global(h1:first-child) { display: none; }
  .readme-body :global(h2) {
    font-size: 1.6rem;
    border-bottom: 1px solid var(--rule-soft);
    padding-bottom: 0.6rem;
    margin-top: 4rem;
  }
  .readme-body :global(img) {
    margin: 2.2rem auto;
    border: 1px solid var(--rule-soft);
    border-radius: 3px;
    background: var(--bg-elev);
    padding: 0.6rem;
  }

  @media (max-width: 920px) {
    .hero { padding: 3rem 0 2.5rem; }
    .hero-grid { grid-template-columns: 1fr; gap: 2rem; }
    .hero-meta { border-left: 0; border-top: 1px solid var(--rule-soft); padding-left: 0; padding-top: 1.2rem; }
    .hero-meta div { grid-template-columns: 7rem 1fr; }
    .thesis-grid { grid-template-columns: 1fr; }
    .thesis-card { padding: 1.6rem 0; border-right: 0; border-bottom: 1px solid var(--rule-soft); }
    .thesis-card:not(:first-child) { padding-left: 0; }
    .thesis-card:last-child { border-bottom: 0; }
    .diagrams-section { padding: 2.8rem 0 2.4rem; }
    .diagram-block { margin-bottom: 2.8rem; }
  }
  @media (max-width: 480px) {
    .hero-meta div { grid-template-columns: 1fr; gap: 0.1rem; padding: 0.7rem 0; }
    .hero-meta dd { font-size: 0.88rem; }
  }
</style>
