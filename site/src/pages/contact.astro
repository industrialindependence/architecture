---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';

export const prerender = true;
---

<Base
  title="Contact"
  description="Contact the Industrial Independence Alliance. Questions, corrections, deployments, contributions."
  current="contact"
>
  <section class="contact-hero">
    <div class="container contact-hero-inner">
      <p class="eyebrow mono">Contact &middot; the Industrial Independence Alliance</p>
      <h1 class="display">
        Drop a line<span class="dot">.</span>
      </h1>
      <p class="lede">
        Questions about the architecture, corrections to the spec,
        deployments in the wild, contributions to the standard,
        or implementation collaboration.
      </p>
      <p class="lede dim">
        We read everything. Replies vary by depth of question.
      </p>
    </div>
  </section>

  <section class="contact-form-section">
    <div class="container contact-grid">
      <div class="contact-form-wrap">
        <ContactForm id="contact-page-form" />
      </div>
      <aside class="contact-meta">
        <p class="meta-eyebrow mono">&sect; Other paths</p>
        <dl>
          <div>
            <dt>GitHub</dt>
            <dd>
              <a href="https://github.com/industrialindependence/architecture" rel="noopener">
                industrialindependence/architecture &rarr;
              </a>
              <p class="meta-hint">Open issues, propose edits, fork the spec.</p>
            </dd>
          </div>
          <div>
            <dt>License</dt>
            <dd>
              <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="noopener">CC&nbsp;BY-SA&nbsp;4.0</a>
              <p class="meta-hint">The text is freely usable. The trademarks are not.</p>
            </dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>
</Base>

<style>
  .contact-hero {
    padding: 5rem 0 3rem;
    background:
      radial-gradient(ellipse 60% 50% at 80% 20%, var(--accent-soft), transparent 60%),
      var(--bg);
    border-bottom: 1px solid var(--rule-soft);
  }
  .contact-hero-inner { max-width: 60rem; }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.74rem;
    color: var(--accent);
    margin: 0 0 1.4rem;
    font-weight: 500;
  }
  .display {
    font-size: clamp(2.2rem, 5vw + 0.4rem, 4rem);
    line-height: 0.96;
    letter-spacing: -0.034em;
    font-weight: 700;
    margin: 0 0 1.4rem;
    font-family: var(--font-display);
  }
  .display .dot { color: var(--accent); }
  .lede {
    font-size: 1.16rem;
    line-height: 1.55;
    max-width: 60ch;
    color: var(--ink);
    margin: 0 0 0.8rem;
  }
  .lede.dim { color: var(--ink-soft); font-size: 1.02rem; }

  .contact-form-section {
    padding: 4rem 0 5rem;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: 3.2rem;
    align-items: start;
  }
  .contact-form-wrap {
    border: 1px solid var(--rule-soft);
    background: var(--bg-elev);
    padding: 1.8rem 1.8rem 1.6rem;
    border-radius: 3px;
  }
  .contact-meta {
    border-left: 1px solid var(--rule-soft);
    padding-left: 1.6rem;
  }
  .meta-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.74rem;
    color: var(--ink-mute);
    margin: 0 0 1rem;
  }
  .contact-meta dl { margin: 0; }
  .contact-meta div {
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--rule-soft);
  }
  .contact-meta div:last-child { border-bottom: 0; }
  .contact-meta dt {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    color: var(--ink-mute);
    margin-bottom: 0.4rem;
  }
  .contact-meta dd {
    margin: 0;
    font-size: 0.92rem;
    color: var(--ink);
  }
  .contact-meta a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1.5px solid var(--rule);
    transition: border-color 120ms ease, color 120ms ease;
  }
  .contact-meta a:hover { color: var(--accent); border-bottom-color: var(--accent); }
  .meta-hint {
    font-size: 0.82rem;
    color: var(--ink-mute);
    margin: 0.4rem 0 0;
    line-height: 1.5;
  }

  @media (max-width: 820px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.4rem; }
    .contact-meta { border-left: 0; padding-left: 0; border-top: 1px solid var(--rule-soft); padding-top: 1.4rem; }
    .contact-hero { padding: 3.5rem 0 2.4rem; }
  }
</style>
