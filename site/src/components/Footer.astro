---
import ContactForm from './ContactForm.astro';
import { withLocale } from '../lib/i18n';

const year = new Date().getFullYear();
const { locale = 'en' } = Astro.props as { locale?: 'en' | 'fr' };
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <p class="brand-line mono">Industrial Independence Alliance</p>
      <p class="tagline">
        {locale === 'fr'
          ? "Souverainete operationnelle pour les infrastructures industrielles. Ni un produit. Ni un framework. Le principe architectural, revendique par son nom."
          : 'Operational sovereignty for industrial infrastructure. Not a product. Not a framework. The architectural principle, claimed by name.'}
      </p>
    </div>

    <div class="footer-block">
      <p class="block-label mono">{locale === 'fr' ? 'Piliers' : 'Pillars'}</p>
      <ul>
        <li><a href={withLocale('/field/', locale)}>{locale === 'fr' ? 'Le terrain' : 'The Field'}</a></li>
        <li><a href={withLocale('/problem/', locale)}>{locale === 'fr' ? 'Le probleme' : 'The Problem'}</a></li>
        <li><a href={withLocale('/claim/', locale)}>{locale === 'fr' ? 'Notre position' : 'Our Claim'}</a></li>
        <li><a href={withLocale('/philosophy/', locale)}>{locale === 'fr' ? 'Notre philosophie' : 'Our Philosophy'}</a></li>
        <li><a href={withLocale('/architecture/', locale)}>{locale === 'fr' ? "L'architecture" : 'The Architecture'}</a></li>
        <li><a href={withLocale('/architecture/docs/', locale)}>{locale === 'fr' ? 'Documentation' : 'Documentation'}</a></li>
        <li><a href={withLocale('/contact/', locale)}>{locale === 'fr' ? 'Contact' : 'Contact'}</a></li>
      </ul>
    </div>

    <div class="footer-block">
      <p class="block-label mono">{locale === 'fr' ? 'Antecedents cites' : 'Prior art cited'}</p>
      <ul>
        <li><a href="https://srpmodel.infracritical.com/srpmodel.php" rel="noopener">SRP Triad &mdash; Robert Radvanovsky, Infracritical</a></li>
        <li><a href="https://www.pera.net" rel="noopener">PERA+ &mdash; Gary Rathwell, Entercon</a></li>
        <li>IEC&nbsp;62443 &middot; ISA-95</li>
        <li class="dim">{locale === 'fr' ? "Travaux independants. Sans affiliation avec l'Alliance ni entre eux." : 'Independent works. Not affiliated with the Alliance or with each other.'}</li>
      </ul>
    </div>

    <div class="footer-block">
      <p class="block-label mono">{locale === 'fr' ? 'Implementations' : 'Implementations'}</p>
      <ul>
        <li><a href="https://www.grassmarlin.com" rel="noopener">MarlinSpike &mdash; {locale === 'fr' ? 'successeur de GrassMarlin' : 'GrassMarlin successor'}</a></li>
        <li><a href="https://www.conversationalfactory.com" rel="noopener">Conversational Factory</a></li>
        <li class="dim">{locale === 'fr' ? 'Construit sur IIA' : 'Built on IIA'}</li>
      </ul>
    </div>

    <div class="footer-block">
      <p class="block-label mono">{locale === 'fr' ? 'Editeur' : 'Publisher'}</p>
      <ul>
        <li>Industrial Independence Alliance</li>
        <li><a href="https://github.com/industrialindependence/architecture" rel="noopener">github &rarr;</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-contact">
    <div class="footer-contact-intro">
      <p class="block-label mono">{locale === 'fr' ? 'Contact rapide' : 'Quick contact'}</p>
      <p class="contact-line">
        {locale === 'fr' ? 'Envoyez un message.' : 'Drop a line.'} <a href={withLocale('/contact/', locale)}>{locale === 'fr' ? 'Formulaire complet' : 'Full form'} &rarr;</a>
      </p>
    </div>
    <div class="footer-contact-form">
      <ContactForm id="footer-contact-form" compact locale={locale} />
    </div>
  </div>

  <div class="container footer-rule">
    <p class="mono small dim">
      &copy; {year} Industrial Independence Alliance &middot;
      <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="noopener">CC&nbsp;BY-SA&nbsp;4.0</a> &middot;
      {locale === 'fr'
        ? '"Industrial Independence Architecture" et "IIA" sont des marques'
        : '"Industrial Independence Architecture" and "IIA" are trademarks'}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    border-top: 1px solid var(--rule);
    background: var(--bg-elev);
    padding: 3rem 0 1.4rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.1fr 0.9fr;
    gap: 2.2rem;
    align-items: start;
  }
  .footer-block li.dim {
    color: var(--ink-mute);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.4rem;
    font-family: var(--font-mono);
  }
  .footer-brand { max-width: 32ch; }
  .brand-line {
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 0.7rem;
  }
  .tagline {
    font-size: 0.92rem;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0;
  }

  .block-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-mute);
    margin: 0 0 0.7rem;
  }
  .footer-block ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-block li {
    font-size: 0.86rem;
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0;
  }
  .footer-block a {
    color: var(--ink-soft);
    text-decoration: none;
  }
  .footer-block a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }

  .footer-contact {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: 2.4rem;
    align-items: start;
    margin-top: 2.6rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule-soft);
  }
  .footer-contact-intro { max-width: 26ch; }
  .footer-contact-intro .contact-line {
    font-size: 0.92rem;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0;
  }
  .footer-contact-intro .contact-line a {
    color: var(--ink);
    border-bottom: 1.5px solid var(--rule);
    text-decoration: none;
    transition: color 120ms ease, border-color 120ms ease;
  }
  .footer-contact-intro .contact-line a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .footer-rule {
    margin-top: 2.4rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--rule-soft);
  }
  .small {
    font-size: 0.74rem;
    color: var(--ink-mute);
    letter-spacing: 0.04em;
    margin: 0;
  }
  .small.dim a { color: var(--ink-mute); }
  .small.dim a:hover { color: var(--accent); }

  @media (max-width: 980px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer-brand { grid-column: span 2; }
    .footer-contact { grid-template-columns: 1fr; gap: 1.4rem; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-brand { grid-column: auto; }
  }
</style>
