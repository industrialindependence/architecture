---
// DomainBoundaryDiagram.astro
// The Domain Boundary — physics (ACS/SRP) vs records (IT/CIA).
// Zero Trust <-> Managed Trust transition at the box.
// Responsive SVG, CSS variables, accessible.
---

<figure class="boundary-diagram" aria-label="Domain boundary: ACS physics versus IT records">
  <svg
    viewBox="0 0 860 320"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-labelledby="db-title db-desc"
    class="boundary-svg"
    preserveAspectRatio="xMidYMid meet"
  >
    <title id="db-title">The domain boundary — ACS versus IT</title>
    <desc id="db-desc">
      Horizontal diagram showing two domains separated by the IIA box.
      Left: ACS domain — physics, action, real-time. Governed by SRP: Safety, Reliability, Performance.
      Security model: Managed Trust.
      Center: the IIA box — the boundary. The moment a value stops requiring real-time action
      and becomes a record, it crosses this boundary.
      Right: IT domain — records, information, historical. Governed by CIA: Confidentiality,
      Integrity, Availability. Security model: Zero Trust.
    </desc>

    <defs>
      <marker id="d-arrow" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
        <path d="M0,0 L0,8 L8,4 z" fill="var(--accent)" />
      </marker>
      <marker id="d-arrow-soft" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
        <path d="M0,0 L0,8 L8,4 z" fill="var(--ink-mute)" />
      </marker>
    </defs>

    <!-- ===== ACS DOMAIN (left) ===== -->
    <rect x="20" y="30" width="290" height="260" rx="3"
      fill="var(--bg-elev)" stroke="var(--rule-soft)" stroke-width="1.5" />

    <text x="165" y="52" class="domain-label" text-anchor="middle">ACS</text>
    <text x="165" y="68" class="domain-sub" text-anchor="middle">Automation &amp; Control Systems</text>

    <!-- SRP triad -->
    <text x="165" y="98" class="triad-eyebrow" text-anchor="middle">SRP Triad</text>
    <g transform="translate(56,108)">
      <rect x="0" y="0" width="218" height="30" rx="2"
        fill="var(--bg)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="36" y="20" class="triad-s">S</text>
      <text x="56" y="20" class="triad-word">Safety</text>
      <text x="109" y="20" class="triad-r">R</text>
      <text x="129" y="20" class="triad-word">Reliability</text>
      <text x="200" y="20" class="triad-p">P</text>
    </g>
    <text x="165" y="158" class="triad-note" text-anchor="middle">Performance</text>

    <!-- What ACS governs -->
    <text x="165" y="190" class="property-label" text-anchor="middle">Acts on physics</text>
    <text x="165" y="207" class="property-label" text-anchor="middle">Valves &middot; interlocks &middot; loops</text>
    <text x="165" y="224" class="property-label" text-anchor="middle">Real-time determinism required</text>

    <!-- Managed Trust label -->
    <rect x="56" y="246" width="218" height="26" rx="2"
      fill="var(--bg)" stroke="var(--accent)" stroke-width="1" />
    <text x="165" y="264" class="trust-label-managed" text-anchor="middle">Managed Trust</text>

    <!-- ===== THE BOX (center boundary) ===== -->
    <g transform="translate(330,20)">
      <rect x="0" y="0" width="200" height="280" rx="4"
        fill="var(--bg)" stroke="var(--ink)" stroke-width="2" />

      <!-- Box header -->
      <text x="100" y="24" class="box-center-label" text-anchor="middle">The box</text>
      <text x="100" y="40" class="box-center-sub" text-anchor="middle">the boundary</text>

      <!-- Divider -->
      <line x1="10" y1="48" x2="190" y2="48" stroke="var(--rule-soft)" stroke-width="0.8" />

      <!-- Zone labels -->
      <text x="100" y="68" class="zone-label" text-anchor="middle">inbound (ACS-facing)</text>
      <rect x="14" y="74" width="172" height="28" rx="2"
        fill="var(--accent-soft)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="100" y="93" class="zone-content" text-anchor="middle">passive · RX-only · ACS NIC</text>

      <text x="100" y="122" class="zone-label" text-anchor="middle">internal DMZ</text>
      <rect x="14" y="128" width="172" height="28" rx="2"
        fill="var(--bg-elev)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="100" y="147" class="zone-content" text-anchor="middle">bus · audit · attestation</text>

      <text x="100" y="176" class="zone-label" text-anchor="middle">outbound (IT-facing)</text>
      <rect x="14" y="182" width="172" height="28" rx="2"
        fill="var(--bg-elev)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="100" y="201" class="zone-content" text-anchor="middle">push · query · mTLS · no HTTP</text>

      <!-- Boundary crossing note -->
      <line x1="14" y1="224" x2="186" y2="224" stroke="var(--accent)" stroke-width="1" stroke-dasharray="3,2" />
      <text x="100" y="242" class="crossing-note" text-anchor="middle">value becomes a record</text>
      <text x="100" y="256" class="crossing-note" text-anchor="middle">at this crossing</text>
      <text x="100" y="270" class="crossing-note-sub" text-anchor="middle">ACS &rarr; IT boundary</text>

    </g>

    <!-- ===== IT DOMAIN (right) ===== -->
    <rect x="550" y="30" width="290" height="260" rx="3"
      fill="var(--bg-elev)" stroke="var(--rule-soft)" stroke-width="1.5" />

    <text x="695" y="52" class="domain-label-it" text-anchor="middle">IT</text>
    <text x="695" y="68" class="domain-sub" text-anchor="middle">Information Technology</text>

    <!-- CIA triad -->
    <text x="695" y="98" class="triad-eyebrow" text-anchor="middle">CIA Triad</text>
    <g transform="translate(586,108)">
      <rect x="0" y="0" width="218" height="30" rx="2"
        fill="var(--bg)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="18" y="20" class="triad-c">C</text>
      <text x="36" y="20" class="triad-word-it">Confidentiality</text>
      <text x="130" y="20" class="triad-i">I</text>
      <text x="148" y="20" class="triad-word-it">Integrity</text>
    </g>
    <text x="695" y="158" class="triad-note-it" text-anchor="middle">Availability</text>

    <!-- What IT governs -->
    <text x="695" y="190" class="property-label-it" text-anchor="middle">Operates on records</text>
    <text x="695" y="207" class="property-label-it" text-anchor="middle">Historical · information · reports</text>
    <text x="695" y="224" class="property-label-it" text-anchor="middle">Best-effort latency acceptable</text>

    <!-- Zero Trust label -->
    <rect x="586" y="246" width="218" height="26" rx="2"
      fill="var(--bg)" stroke="var(--rule-soft)" stroke-width="1" />
    <text x="695" y="264" class="trust-label-zero" text-anchor="middle">Zero Trust</text>

    <!-- ===== FLOW ARROWS ===== -->

    <!-- ACS -> box (physics crossing) -->
    <line x1="310" y1="160" x2="330" y2="160" stroke="var(--accent)" stroke-width="2" marker-end="url(#d-arrow)" />
    <text x="313" y="152" class="flow-arrow-label">data out</text>

    <!-- box -> IT (record) -->
    <line x1="530" y1="160" x2="550" y2="160" stroke="var(--ink-soft)" stroke-width="2" marker-end="url(#d-arrow-soft)" />
    <text x="532" y="152" class="flow-arrow-label">record</text>

    <!-- Trust transition label (center, bottom) -->
    <text x="430" y="312" class="trust-transition" text-anchor="middle">
      Zero Trust &#x21C6; Managed Trust
    </text>

  </svg>
  <figcaption class="diagram-caption mono">
    The domain boundary &mdash; SRP governs the ACS substrate &middot; CIA governs information &middot; PERA+ framing: Zero Trust &harr; Managed Trust
  </figcaption>
</figure>

<style>
  .boundary-diagram {
    margin: 2.4rem 0;
  }
  .boundary-svg {
    width: 100%;
    height: auto;
    display: block;
    background: var(--bg-elev);
    border: 1px solid var(--rule-soft);
    border-radius: 4px;
  }

  .boundary-svg .domain-label {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    fill: var(--ink);
    letter-spacing: -0.02em;
  }
  .boundary-svg .domain-label-it {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    fill: var(--ink-soft);
    letter-spacing: -0.02em;
  }
  .boundary-svg .domain-sub {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--ink-mute);
    letter-spacing: 0.06em;
  }
  .boundary-svg .triad-eyebrow {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    fill: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .boundary-svg .triad-s {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    fill: var(--accent);
  }
  .boundary-svg .triad-r {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    fill: var(--accent);
  }
  .boundary-svg .triad-p {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    fill: var(--accent);
  }
  .boundary-svg .triad-word {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--ink);
  }
  .boundary-svg .triad-note {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--ink-mute);
  }
  .boundary-svg .triad-c {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    fill: var(--ink-soft);
  }
  .boundary-svg .triad-i {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    fill: var(--ink-soft);
  }
  .boundary-svg .triad-word-it {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--ink-soft);
  }
  .boundary-svg .triad-note-it {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--ink-mute);
  }
  .boundary-svg .property-label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    fill: var(--ink);
  }
  .boundary-svg .property-label-it {
    font-family: var(--font-mono);
    font-size: 9.5px;
    fill: var(--ink-soft);
  }
  .boundary-svg .trust-label-managed {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    fill: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .boundary-svg .trust-label-zero {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    fill: var(--ink-soft);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* center box */
  .boundary-svg .box-center-label {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    fill: var(--ink);
    letter-spacing: 0.04em;
  }
  .boundary-svg .box-center-sub {
    font-family: var(--font-mono);
    font-size: 8.5px;
    fill: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .boundary-svg .zone-label {
    font-family: var(--font-mono);
    font-size: 8.5px;
    fill: var(--ink-mute);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .boundary-svg .zone-content {
    font-family: var(--font-mono);
    font-size: 8px;
    fill: var(--ink-soft);
  }
  .boundary-svg .crossing-note {
    font-family: var(--font-mono);
    font-size: 8.5px;
    fill: var(--accent);
    font-style: italic;
  }
  .boundary-svg .crossing-note-sub {
    font-family: var(--font-mono);
    font-size: 7.5px;
    fill: var(--ink-mute);
  }

  /* arrows */
  .boundary-svg .flow-arrow-label {
    font-family: var(--font-mono);
    font-size: 7.5px;
    fill: var(--ink-mute);
  }
  .boundary-svg .trust-transition {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    fill: var(--ink-mute);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .diagram-caption {
    font-family: var(--font-mono);
    font-size: 0.78em;
    color: var(--ink-mute);
    margin-top: 0.6rem;
    text-align: center;
    letter-spacing: 0.02em;
  }
</style>
