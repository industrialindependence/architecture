---
// FractalDiagram.astro
// The IIA Fractal — same unit, deployed wherever a zone publishes outward.
// Two panes: the anatomy of one box (left), and where boxes actually appear (right).
---

<figure class="fractal-diagram" aria-label="The IIA Fractal diagram">
  <svg
    viewBox="0 0 800 540"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-labelledby="fractal-title fractal-desc"
    class="fractal-svg"
    preserveAspectRatio="xMidYMid meet"
  >
    <title id="fractal-title">The Fractal — a box at the head of every zone, the secure edge gateway</title>
    <desc id="fractal-desc">
      Two-pane diagram. Left pane shows the internal anatomy of one secure edge gateway:
      inbound, internal DMZ, outbound, and management partitions, with a local lake — the
      decentralized historian — as source of truth. Right pane shows the deployment rule:
      every zone has a gateway at its head. Inside the zone are pools of data (process,
      device telemetry, network, asset inventory, event streams, topology) fed by the
      gateway's witness (passive) and active poll. Devices contributing to those pools can
      be any security level; the security boundary lives at the gateway, not at every
      device. The gateway publishes information governed by CIA outbound through a secure
      conduit (with a hardware data diode in the SL4 ideal realization) to whatever the
      zone's consumers are. The gateway is identical at every zone; the operator defines
      what counts as a zone.
    </desc>

    <defs>
      <marker id="frac-arrow-up" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="var(--accent)" />
      </marker>
      <marker id="frac-arrow-neutral" markerWidth="7" markerHeight="7" refX="5" refY="2.5" orient="auto">
        <path d="M0,0 L0,5 L7,2.5 z" fill="var(--ink-soft)" />
      </marker>
      <!-- Diode glyph: triangle pointing up with a bar above (no return path) -->
      <symbol id="frac-diode" viewBox="0 0 28 28">
        <path d="M 4 22 L 24 22 L 14 6 Z"
          fill="var(--bg-elev)" stroke="var(--accent)" stroke-width="1.6" stroke-linejoin="round" />
        <line x1="4" y1="3" x2="24" y2="3"
          stroke="var(--accent)" stroke-width="2" stroke-linecap="round" />
      </symbol>
    </defs>

    <!-- ===== HEADER ===== -->
    <g>
      <text x="400" y="26" class="frac-eyebrow" text-anchor="middle">The Fractal</text>
      <text x="400" y="44" class="frac-subtitle" text-anchor="middle">the unit is the same &middot; scope varies &middot; boxes exist where zones publish outward</text>
    </g>

    <!-- ===== CENTER DIVIDER ===== -->
    <line x1="400" y1="62" x2="400" y2="500" stroke="var(--rule-soft)" stroke-width="1" stroke-dasharray="4,4" />

    <!-- ============================================== -->
    <!-- ===== LEFT PANE — THE UNIT (anatomy) ========= -->
    <!-- ============================================== -->
    <g class="pane pane-left">
      <text x="60" y="80" class="pane-eyebrow">The Unit &middot; anatomy</text>
      <text x="60" y="96" class="pane-sub">identical at every scope</text>

      <!-- Outer box -->
      <rect x="60" y="116" width="300" height="350" rx="3"
        fill="var(--bg-elev)" stroke="var(--accent)" stroke-width="1.5" />

      <!-- INBOUND -->
      <rect x="76" y="132" width="268" height="68" rx="2"
        fill="var(--bg)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="86" y="150" class="part-label">INBOUND &middot; ACS-facing</text>
      <text x="86" y="167" class="part-note">witness (passive) &middot; active poll &middot; classify</text>
      <text x="86" y="182" class="part-note">no IP TX &middot; no external listeners</text>

      <!-- DMZ -->
      <rect x="76" y="208" width="268" height="62" rx="2"
        fill="var(--bg)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="86" y="226" class="part-label">INTERNAL DMZ</text>
      <text x="86" y="243" class="part-note">in-flight bus &middot; transient</text>
      <text x="86" y="258" class="part-note">no durable state here</text>

      <!-- OUTBOUND -->
      <rect x="76" y="278" width="268" height="68" rx="2"
        fill="var(--bg)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="86" y="296" class="part-label">OUTBOUND &middot; IT-facing</text>
      <text x="86" y="313" class="part-note">secure publish &middot; structured query API</text>
      <text x="86" y="328" class="part-note">the only external access into the zone</text>

      <!-- MANAGEMENT -->
      <rect x="76" y="354" width="268" height="44" rx="2"
        fill="var(--bg)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="86" y="372" class="part-label">MANAGEMENT</text>
      <text x="86" y="388" class="part-note">local ops UI &middot; signed-artifact ingress only</text>

      <!-- Lake — labelled band at the bottom -->
      <rect x="76" y="406" width="268" height="44" rx="2"
        fill="var(--accent-soft)" stroke="var(--accent)" stroke-width="1" stroke-dasharray="3,2" />
      <text x="86" y="424" class="part-label">LOCAL LAKE &middot; HISTORIAN</text>
      <text x="86" y="440" class="part-note">source of truth on the box &middot; decentralized historian</text>
    </g>

    <!-- ============================================== -->
    <!-- ===== RIGHT PANE — THE DEPLOYMENT (where) ==== -->
    <!-- ============================================== -->
    <g class="pane pane-right">
      <text x="420" y="80" class="pane-eyebrow">The Deployment &middot; where</text>
      <text x="420" y="96" class="pane-sub">a box at the head of every zone &middot; the secure edge gateway</text>

      <!-- ==== Consumers band (top) ==== -->
      <rect x="438" y="116" width="322" height="30" rx="2"
        fill="var(--bg)" stroke="var(--rule-soft)" stroke-width="1" stroke-dasharray="4,3" />
      <text x="448" y="128" class="depl-band-label">CONSUMERS</text>
      <text x="448" y="140" class="depl-band-note">internet &middot; plant &middot; partner &middot; regulator &middot; whoever</text>

      <!-- Lower segment: from box up to just below diode glyph -->
      <line x1="599" y1="198" x2="599" y2="186" stroke="var(--accent)" stroke-width="1.5" />
      <!-- Diode glyph on the secure conduit -->
      <use href="#frac-diode" x="585" y="156" width="28" height="28" />
      <!-- Upper segment: from just above diode up to consumers band -->
      <line x1="599" y1="156" x2="599" y2="150" stroke="var(--accent)" stroke-width="1.5" marker-end="url(#frac-arrow-up)" />

      <text x="624" y="172" class="depl-flow-label">secure conduit &middot; information (CIA)</text>
      <text x="624" y="184" class="depl-flow-sub">SL4 ideal: hardware data diode, no return path</text>

      <!-- ==== Box (the secure edge gateway, at the head of the zone) ==== -->
      <rect x="538" y="198" width="124" height="50" rx="2"
        fill="var(--bg-elev)" stroke="var(--accent)" stroke-width="1.6" />
      <text x="600" y="216" class="depl-box-label" text-anchor="middle">box</text>
      <text x="600" y="230" class="depl-sub" text-anchor="middle">secure edge gateway</text>
      <text x="600" y="242" class="depl-sub" text-anchor="middle">witness &middot; historian &middot; publish</text>

      <!-- Arrow up from zone interior to box + label -->
      <line x1="599" y1="286" x2="599" y2="250" stroke="var(--ink-soft)" stroke-width="1.3" marker-end="url(#frac-arrow-neutral)" />
      <text x="668" y="268" class="depl-flow-label">ACS data (SRP)</text>
      <text x="668" y="280" class="depl-flow-sub">witness &middot; active poll</text>

      <!-- ==== Zone — bounded region containing pools of data ==== -->
      <rect x="438" y="286" width="322" height="170" rx="3"
        fill="var(--bg)" stroke="var(--rule-soft)" stroke-width="1.2" stroke-dasharray="4,3" />
      <text x="448" y="302" class="depl-band-label">ZONE &middot; OPERATOR-DEFINED</text>
      <text x="448" y="314" class="depl-band-note">production &middot; plant &middot; site &middot; corp &middot; any boundary</text>

      <text x="599" y="332" class="depl-pools-header" text-anchor="middle">POOLS OF DATA</text>

      <!-- Six pool ellipses in a 3x2 grid -->
      <ellipse cx="496" cy="352" rx="54" ry="13"
        fill="var(--bg-elev)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="496" y="356" class="depl-pool-label" text-anchor="middle">process data</text>

      <ellipse cx="600" cy="352" rx="54" ry="13"
        fill="var(--bg-elev)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="600" y="356" class="depl-pool-label" text-anchor="middle">device telemetry</text>

      <ellipse cx="704" cy="352" rx="54" ry="13"
        fill="var(--bg-elev)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="704" y="356" class="depl-pool-label" text-anchor="middle">network data</text>

      <ellipse cx="496" cy="386" rx="54" ry="13"
        fill="var(--bg-elev)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="496" y="390" class="depl-pool-label" text-anchor="middle">asset inventory</text>

      <ellipse cx="600" cy="386" rx="54" ry="13"
        fill="var(--bg-elev)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="600" y="390" class="depl-pool-label" text-anchor="middle">event streams</text>

      <ellipse cx="704" cy="386" rx="54" ry="13"
        fill="var(--bg-elev)" stroke="var(--rule-soft)" stroke-width="1" />
      <text x="704" y="390" class="depl-pool-label" text-anchor="middle">topology</text>

      <!-- Inside-zone caption -->
      <text x="599" y="418" class="depl-inside-note" text-anchor="middle">any SL device contributes &middot; gateway is the security boundary</text>
      <text x="599" y="434" class="depl-inside-note" text-anchor="middle">witness (passive) + active poll feed every pool into the historian</text>

      <!-- ==== Fractal property strip at bottom ==== -->
      <text x="420" y="478" class="depl-rule">FRACTAL</text>
      <text x="420" y="492" class="depl-rule-body">same pattern at every zone &middot; operator decides what counts as a zone</text>
    </g>

  </svg>
  <figcaption class="diagram-caption mono">
    The Fractal &mdash; a secure edge gateway at the head of every zone. Inside the zone are pools of data fed by the gateway's witness (passive) and active poll; devices contributing can be any security level. The gateway publishes information securely outbound through a conduit (with a hardware data diode in the SL4 ideal realization) to whatever the zone's consumers are. The gateway is identical at every zone; the operator defines what counts as a zone.
  </figcaption>
</figure>

<style>
  .fractal-diagram {
    margin: 2.4rem auto;
    max-width: 880px;
  }
  .fractal-svg {
    width: 100%;
    height: auto;
    display: block;
    background: var(--bg-elev);
    border: 1px solid var(--rule-soft);
    border-radius: 4px;
  }

  .fractal-svg .frac-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    fill: var(--ink);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .fractal-svg .frac-subtitle {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--ink-mute);
    letter-spacing: 0.05em;
  }
  .fractal-svg .pane-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    fill: var(--accent);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .fractal-svg .pane-sub {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--ink-mute);
    letter-spacing: 0.04em;
  }
  .fractal-svg .part-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    fill: var(--ink);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .fractal-svg .part-note {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--ink-mute);
  }

  .fractal-svg .depl-box-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    fill: var(--ink);
    letter-spacing: 0.04em;
  }
  .fractal-svg .depl-sub {
    font-family: var(--font-mono);
    font-size: 8.5px;
    fill: var(--ink-mute);
  }
  .fractal-svg .depl-zone-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    fill: var(--ink-soft);
  }
  .fractal-svg .depl-zone-note {
    font-family: var(--font-mono);
    font-size: 8px;
    fill: var(--ink-mute);
    font-style: italic;
  }
  .fractal-svg .depl-band-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    fill: var(--ink);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .fractal-svg .depl-band-note {
    font-family: var(--font-mono);
    font-size: 8.5px;
    fill: var(--ink-mute);
  }
  .fractal-svg .depl-flow-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    fill: var(--accent);
    letter-spacing: 0.04em;
  }
  .fractal-svg .depl-flow-sub {
    font-family: var(--font-mono);
    font-size: 8px;
    fill: var(--ink-mute);
  }
  .fractal-svg .depl-dev-label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    fill: var(--ink);
  }
  .fractal-svg .depl-dev-sl {
    font-family: var(--font-mono);
    font-size: 8.5px;
    fill: var(--ink-mute);
    letter-spacing: 0.04em;
  }
  .fractal-svg .depl-inside-note {
    font-family: var(--font-mono);
    font-size: 8.5px;
    fill: var(--ink-soft);
    font-style: italic;
  }
  .fractal-svg .depl-pools-header {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    fill: var(--ink-soft);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .fractal-svg .depl-pool-label {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--ink);
    letter-spacing: 0.02em;
  }
  .fractal-svg .depl-scope {
    font-family: var(--font-mono);
    font-size: 8.5px;
    fill: var(--ink-mute);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .fractal-svg .depl-rule {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    fill: var(--accent);
    letter-spacing: 0.14em;
  }
  .fractal-svg .depl-rule-body {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--ink);
  }
  .fractal-svg .frac-legend {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--ink-soft);
  }

  .diagram-caption {
    font-family: var(--font-mono);
    font-size: 0.78em;
    color: var(--ink-mute);
    margin-top: 0.6rem;
    text-align: center;
    letter-spacing: 0.02em;
    max-width: 80ch;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }
</style>
