---
interface Props {
  pillar: 'field' | 'problem' | 'claim' | 'philosophy' | 'architecture';
  size?: number;
}

const { pillar, size = 28 } = Astro.props;
const label = {
  field: 'Sparse field — observation',
  problem: 'Fracture — what stands in the way',
  claim: 'Lines of assertion — the claim',
  philosophy: 'Nested form — recursive position',
  architecture: 'Diode glyph — secure boundary'
}[pillar];
---

<span class="pillar-icon" data-pillar={pillar} role="img" aria-label={label}>
  {pillar === 'field' && (
    <svg viewBox="0 0 24 24" width={size} height={size} fill="currentColor" aria-hidden="true">
      <circle cx="4" cy="4" r="1.4" />
      <circle cx="12" cy="4" r="1.4" />
      <circle cx="20" cy="4" r="1.4" />
      <circle cx="4" cy="12" r="1.4" />
      <circle cx="12" cy="12" r="1.4" />
      <circle cx="20" cy="12" r="1.4" />
      <circle cx="4" cy="20" r="1.4" />
      <circle cx="12" cy="20" r="1.4" />
      <circle cx="20" cy="20" r="1.4" />
    </svg>
  )}

  {pillar === 'problem' && (
    <svg viewBox="0 0 24 24" width={size} height={size} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="4,20 9,15 8,11 14,9 13,5 20,4" />
    </svg>
  )}

  {pillar === 'claim' && (
    <svg viewBox="0 0 24 24" width={size} height={size} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <line x1="3.5" y1="7" x2="20.5" y2="7" />
      <line x1="3.5" y1="13" x2="20.5" y2="13" />
      <line x1="3.5" y1="19" x2="14" y2="19" />
    </svg>
  )}

  {pillar === 'philosophy' && (
    <svg viewBox="0 0 24 24" width={size} height={size} fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" aria-hidden="true">
      <path d="M 12 2.5 L 21.5 12 L 12 21.5 L 2.5 12 Z" />
      <path d="M 12 8 L 16 12 L 12 16 L 8 12 Z" fill="currentColor" />
    </svg>
  )}

  {pillar === 'architecture' && (
    <svg viewBox="0 0 24 24" width={size} height={size} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="4" y1="4" x2="20" y2="4" />
      <path d="M 4 22 L 20 22 L 12 8 Z" />
    </svg>
  )}
</span>

<style>
  .pillar-icon {
    display: inline-flex;
    color: var(--accent);
    line-height: 0;
  }
</style>
