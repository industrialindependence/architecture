---
const { current = '' } = Astro.props as { current?: string };
const links = [
  { href: '/philosophy/', label: 'The Philosophy', key: 'philosophy' },
  { href: '/architecture/', label: 'The Architecture', key: 'architecture' },
  { href: '/architecture/docs/', label: 'Documentation', key: 'docs' }
];
---

<header class="site-header">
  <div class="container header-row">
    <a href="/" class="brand" aria-label="Industrial Independence Alliance, home">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6">
          <rect x="3" y="3" width="18" height="18" rx="1" />
          <rect x="7" y="7" width="10" height="10" rx="0.5" />
          <line x1="3" y1="12" x2="7" y2="12" />
          <line x1="17" y1="12" x2="21" y2="12" />
          <line x1="12" y1="3" x2="12" y2="7" />
          <line x1="12" y1="17" x2="12" y2="21" />
        </svg>
      </span>
      <span class="brand-text">
        <span class="brand-acronym">IIA</span>
        <span class="brand-full">Industrial Independence Alliance</span>
      </span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      {links.map((l) => {
        const active =
          l.key === current ||
          (l.key === 'architecture' && current.startsWith('architecture')) ||
          (l.key === 'docs' && current === 'docs') ||
          (l.key === 'philosophy' && current.startsWith('philosophy'));
        return (
          <a href={l.href} class={active ? 'is-active' : ''}>{l.label}</a>
        );
      })}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in oklab, var(--bg) 92%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--rule-soft);
  }
  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--ink);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }
  .brand:hover { color: var(--accent); }
  .brand-mark {
    color: var(--accent);
    display: inline-flex;
  }
  .brand-text { display: inline-flex; align-items: baseline; gap: 0.6rem; }
  .brand-acronym {
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.08em;
  }
  .brand-full {
    color: var(--ink-soft);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }
  .site-nav {
    display: flex;
    gap: 1.6rem;
    flex-wrap: wrap;
  }
  .site-nav a {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-soft);
    padding: 0.3rem 0;
    border-bottom: 1.5px solid transparent;
    transition: color 120ms ease, border-color 120ms ease;
  }
  .site-nav a:hover { color: var(--ink); border-bottom-color: var(--accent); }
  .site-nav a.is-active {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 820px) {
    .brand-full { display: none; }
    .header-row { gap: 1rem; }
    .site-nav { gap: 1rem; }
    .site-nav a { font-size: 0.74rem; }
  }
  @media (max-width: 560px) {
    .header-row { flex-direction: column; align-items: flex-start; gap: 0.7rem; padding: 0.8rem 0; }
    .site-nav { width: 100%; gap: 0.8rem 1.2rem; }
    .site-nav a { font-size: 0.7rem; }
  }
</style>
