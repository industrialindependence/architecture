---
import { stripLocalePrefix, withLocale } from '../lib/i18n';

const { current = '', locale = 'en' } = Astro.props as { current?: string; locale?: 'en' | 'fr' };
const currentPath = Astro.locals.originalPathname ?? Astro.url.pathname;
const languageToggleHref = locale === 'fr' ? stripLocalePrefix(currentPath) : withLocale(currentPath, 'fr');
const links = [
  { href: '/field/', en: 'The Field', fr: 'Le terrain', key: 'field' },
  { href: '/problem/', en: 'The Problem', fr: 'Le probleme', key: 'problem' },
  { href: '/claim/', en: 'Our Claim', fr: 'Notre position', key: 'claim' },
  { href: '/philosophy/', en: 'Our Philosophy', fr: 'Notre philosophie', key: 'philosophy' },
  { href: '/architecture/', en: 'The Architecture', fr: "L'architecture", key: 'architecture' },
  { href: '/architecture/docs/', en: 'Docs', fr: 'Docs', key: 'docs' },
  { href: '/contact/', en: 'Contact', fr: 'Contact', key: 'contact' }
];
---

<header class="site-header">
  <div class="container header-row">
    <a href={withLocale('/', locale)} class="brand" aria-label={locale === 'fr' ? "Industrial Independence Alliance, accueil" : 'Industrial Independence Alliance, home'}>
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="24" height="24">
          <rect x="2.5" y="2.5" width="19" height="19" rx="1.4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
          <rect x="7" y="7" width="10" height="10" rx="0.8" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
          <rect x="10.5" y="10.5" width="3" height="3" rx="0.4" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
        </svg>
      </span>
      <span class="brand-text">
        <span class="brand-acronym">IIA</span>
        <span class="brand-full">Industrial Independence Alliance</span>
      </span>
    </a>
    <nav class="site-nav" aria-label={locale === 'fr' ? 'Primaire' : 'Primary'}>
      {links.map((l) => {
        const active =
          l.key === current ||
          (l.key === 'philosophy' && current.startsWith('philosophy')) ||
          (l.key === 'architecture' && current.startsWith('architecture')) ||
          (l.key === 'docs' && current === 'docs');
        return (
          <a href={withLocale(l.href, locale)} class={active ? 'is-active' : ''}>{locale === 'fr' ? l.fr : l.en}</a>
        );
      })}
      <a href={languageToggleHref} class="lang-link">{locale === 'fr' ? 'EN' : 'FR'}</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in oklab, var(--bg) 92%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--rule-soft);
  }
  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--ink);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }
  .brand:hover { color: var(--accent); }
  .brand-mark {
    color: var(--accent);
    display: inline-flex;
  }
  .brand-text { display: inline-flex; align-items: baseline; gap: 0.6rem; }
  .brand-acronym {
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.08em;
  }
  .brand-full {
    color: var(--ink-soft);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }
  .site-nav {
    display: flex;
    gap: 1.1rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .site-nav a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-soft);
    padding: 0.3rem 0;
    border-bottom: 1.5px solid transparent;
    transition: color 120ms ease, border-color 120ms ease;
    white-space: nowrap;
  }
  .site-nav a:hover { color: var(--ink); border-bottom-color: var(--accent); }
  .site-nav a.is-active,
  .site-nav a.lang-link {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 1100px) {
    .brand-full { display: none; }
    .header-row { gap: 1rem; }
    .site-nav { gap: 0.9rem; }
    .site-nav a { font-size: 0.72rem; }
  }
  @media (max-width: 720px) {
    .header-row { flex-direction: column; align-items: flex-start; gap: 0.7rem; padding: 0.8rem 0; }
    .site-nav { width: 100%; gap: 0.7rem 1rem; }
    .site-nav a { font-size: 0.68rem; }
  }
</style>
